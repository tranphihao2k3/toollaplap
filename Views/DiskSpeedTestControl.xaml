<UserControl x:Class="LapLapAutoTool.Views.DiskSpeedTestControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Background="#070A10">
    <Grid Margin="24,18,24,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
            <Border Width="3" Height="20" CornerRadius="2" Background="#F97316" Margin="0,0,10,0" VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect Color="#F97316" BlurRadius="4" ShadowDepth="0" Opacity="0.3"/>
                </Border.Effect>
            </Border>
            <TextBlock Text="STORAGE_SPEED_DIAGNOSTICS" FontSize="22" FontWeight="Black" Foreground="White"
                       FontFamily="Rajdhani, Consolas"/>
        </StackPanel>
        <TextBlock Grid.Row="1" Text="Đo tốc độ đọc/ghi thực tế liên tục — cập nhật realtime"
                   FontSize="13.5" Foreground="#6A9AAA" FontWeight="SemiBold" Margin="0,4,0,18" FontFamily="Rajdhani, Consolas"/>

        <Grid Grid.Row="2" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Kích thước test: " Foreground="#4A7A8A" FontSize="12" VerticalAlignment="Center"
                           FontFamily="Rajdhani, Consolas"/>
                <ComboBox x:Name="SizeCombo" SelectedIndex="1"
                          Background="#0B101A" Foreground="Black" BorderBrush="#35F97316"
                          FontSize="12" Padding="10,6" Width="110" Margin="8,0">
                    <ComboBox.ItemContainerStyle>
                        <Style TargetType="ComboBoxItem">
                            <Setter Property="Foreground" Value="Black"/>
                        </Style>
                    </ComboBox.ItemContainerStyle>
                    <ComboBoxItem Content="64 MB"/>
                    <ComboBoxItem Content="128 MB"/>
                    <ComboBoxItem Content="256 MB"/>
                    <ComboBoxItem Content="512 MB"/>
                </ComboBox>
                <TextBlock Text="Lặp liên tục: " Foreground="#4A7A8A" FontSize="12" VerticalAlignment="Center"
                           FontFamily="Rajdhani, Consolas"/>
                <CheckBox x:Name="LoopCheck" IsChecked="True" VerticalAlignment="Center"
                          Foreground="White" FontSize="12" Margin="8,0" Content="Bật"/>
            </StackPanel>
            <Button Grid.Column="1" x:Name="BtnStart" Content="▶ Bắt đầu" Click="StartTest"
                    Padding="18,9" Style="{StaticResource ModernButton}" FontSize="13" Margin="0,0,8,0"/>
            <Button Grid.Column="2" x:Name="BtnStop" Content="⏹ Dừng" Click="StopTest"
                    Padding="14,9" Style="{StaticResource SecondaryButton}" FontSize="13"
                    IsEnabled="False"/>
        </Grid>

        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <UniformGrid Grid.Row="0" Columns="2" Margin="0,0,0,14">
                <Border Background="#0B101A" CornerRadius="10" Padding="16,14" Margin="0,0,8,0"
                        BorderBrush="#35F59E0B" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect Color="#F59E0B" BlurRadius="6" ShadowDepth="0" Opacity="0.1"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="GHI (WRITE)" Foreground="#4A7A8A" FontSize="11.5" FontWeight="ExtraBold"
                                   FontFamily="Rajdhani, Consolas"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,6" VerticalAlignment="Center">
                            <TextBlock x:Name="WriteSpeedText" Text="—" FontSize="32" FontWeight="Black" Foreground="#F59E0B"
                                       FontFamily="Rajdhani, Consolas"/>
                            <TextBlock Text=" MB/s" FontSize="14" Foreground="#4A7A8A" VerticalAlignment="Bottom" Margin="4,0,0,4"
                                       FontFamily="Rajdhani, Consolas"/>
                        </StackPanel>
                        <Border Background="#05080E" CornerRadius="4" Height="12">
                            <Border x:Name="WriteBar" Background="#F59E0B" CornerRadius="4" HorizontalAlignment="Left" Width="0"/>
                        </Border>
                        <TextBlock x:Name="WriteMaxText" Text="Max: — MB/s" Foreground="#2A3A4A" FontSize="11.5" Margin="0,4,0,0"
                                   FontFamily="Rajdhani, Consolas"/>
                    </StackPanel>
                </Border>

                <Border Background="#0B101A" CornerRadius="10" Padding="16,14" Margin="8,0,0,0"
                        BorderBrush="#3500D2FF" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect Color="#00D2FF" BlurRadius="6" ShadowDepth="0" Opacity="0.1"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="ĐỌC (READ)" Foreground="#4A7A8A" FontSize="11.5" FontWeight="ExtraBold"
                                   FontFamily="Rajdhani, Consolas"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,6" VerticalAlignment="Center">
                            <TextBlock x:Name="ReadSpeedText" Text="—" FontSize="32" FontWeight="Black" Foreground="#00D2FF"
                                       FontFamily="Rajdhani, Consolas"/>
                            <TextBlock Text=" MB/s" FontSize="14" Foreground="#4A7A8A" VerticalAlignment="Bottom" Margin="4,0,0,4"
                                       FontFamily="Rajdhani, Consolas"/>
                        </StackPanel>
                        <Border Background="#05080E" CornerRadius="4" Height="12">
                            <Border x:Name="ReadBar" Background="#00D2FF" CornerRadius="4" HorizontalAlignment="Left" Width="0"/>
                        </Border>
                        <TextBlock x:Name="ReadMaxText" Text="Max: — MB/s" Foreground="#2A3A4A" FontSize="11.5" Margin="0,4,0,0"
                                   FontFamily="Rajdhani, Consolas"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border Grid.Row="1" Background="#05080E" CornerRadius="8" BorderBrush="#1AF97316" BorderThickness="1">
                <Grid>
                    <Canvas x:Name="ChartCanvas" ClipToBounds="True">
                        <Polyline x:Name="WriteChart" Stroke="#F59E0B" StrokeThickness="2" Opacity="0.8"/>
                        <Polyline x:Name="ReadChart"  Stroke="#00D2FF" StrokeThickness="2" Opacity="0.8"/>
                    </Canvas>
                    <StackPanel VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,8,12,0">
                        <StackPanel Orientation="Horizontal">
                            <Rectangle Fill="#F59E0B" Width="16" Height="3" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="Write" Foreground="#F59E0B" FontSize="11" FontFamily="Rajdhani, Consolas"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <Rectangle Fill="#00D2FF" Width="16" Height="3" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="Read" Foreground="#00D2FF" FontSize="11" FontFamily="Rajdhani, Consolas"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="4" Background="#0B101A" CornerRadius="6" Padding="12,7" Margin="0,12,0,0"
                BorderBrush="#1AF97316" BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="#1E293B" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock x:Name="StatusText" Text="Sẵn sàng — nhấn Bắt đầu để test"
                           Foreground="#4A7A8A" FontSize="12" VerticalAlignment="Center"
                           FontFamily="Rajdhani, Consolas"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
