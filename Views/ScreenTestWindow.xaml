<Window x:Class="LapLapAutoTool.Views.ScreenTestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Test Màn Hình - Nhấn ESC để thoát" 
        WindowStyle="None" WindowState="Maximized"
        Background="Black"
        KeyDown="Window_KeyDown"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        Cursor="None">
    <Grid>
        <Border x:Name="ColorPanel" Background="Black"/>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock x:Name="InfoText" 
                       Text="CLICK để đổi màu | ESC để thoát" 
                       Foreground="White" FontSize="20" 
                       HorizontalAlignment="Center"
                       FontFamily="Segoe UI" FontWeight="Light"
                       Opacity="0.6"/>
            <TextBlock x:Name="ColorNameText" 
                       Text="ĐEN" 
                       Foreground="White" FontSize="48" FontWeight="Black"
                       HorizontalAlignment="Center" Margin="0,10,0,0"
                       FontFamily="Segoe UI"/>
            <TextBlock x:Name="HintText"
                       Text="Tìm điểm sáng bất thường trên các màu đen/trắng" 
                       Foreground="White" FontSize="13"
                       HorizontalAlignment="Center" Margin="0,5,0,0"
                       Opacity="0.5" FontFamily="Segoe UI"/>
        </StackPanel>
        <TextBlock x:Name="StepText" 
                   Text="1 / 6" 
                   Foreground="White" FontSize="14" Opacity="0.4"
                   HorizontalAlignment="Right" VerticalAlignment="Bottom"
                   Margin="0,0,20,20"/>
    </Grid>
</Window>
