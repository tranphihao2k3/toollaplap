<UserControl x:Class="LapLapAutoTool.Views.BackupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d">
    <Grid Margin="18,14,18,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Compact header -->
        <Grid Grid.Row="0" Margin="0,0,0,14">
            <StackPanel>
                <TextBlock Text="Sao lưu dữ liệu" FontSize="22" FontWeight="Black" Foreground="White"/>
                <TextBlock Text="Chọn thư mục cần sao lưu trước khi cài lại Windows"
                           Foreground="{StaticResource MutedTextBrush}" FontSize="13"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Folder list (compact) -->
            <Border Grid.Column="0" Style="{StaticResource ModernCard}" Margin="0,0,10,0" Padding="14,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="DANH SÁCH THƯ MỤC" FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}" Margin="0,0,0,12"/>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding BackupFolders}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8,5" Margin="0,0,0,4" CornerRadius="6">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#1E293B"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <CheckBox IsChecked="{Binding IsSelected}" VerticalContentAlignment="Center">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="110"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Name}" Foreground="White"
                                                           FontSize="13" FontWeight="SemiBold"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Path}"
                                                           Foreground="{StaticResource MutedTextBrush}"
                                                           FontSize="11" VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </Grid>
                                        </CheckBox>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Right: Action panel (compact) -->
            <Border Grid.Column="1" Style="{StaticResource ModernCard}" Margin="0,0,0,0" Padding="16,16">
                <StackPanel>
                    <TextBlock Text="SẴN SÀNG SAO LƯU" FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}" Margin="0,0,0,10"
                               HorizontalAlignment="Center"/>

                    <!-- Info box -->
                    <Border Background="#0F172A" CornerRadius="8" Padding="12,10" Margin="0,0,0,18">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="📁 " FontSize="12"/>
                                <TextBlock Text="Nén vào thư mục mới trên Desktop" FontSize="11" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚠ " FontSize="12"/>
                                <TextBlock Text="Đảm bảo ổ C còn đủ dung lượng" FontSize="11" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Button Content="⬆  Bắt đầu sao lưu"
                            Command="{Binding BackupDataCommand}"
                            Style="{StaticResource ModernButton}"
                            Height="44" FontSize="15" FontWeight="Bold"/>

                    <TextBlock Text="Tự động tạo: Backup_CaiWin_..."
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="10" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Loading overlay -->
        <Grid Grid.RowSpan="2" Background="#DD000000"
              Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="420">
                <TextBlock Text="{Binding StatusText}" Foreground="White" Margin="0,0,0,16"
                           FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"
                           TextAlignment="Center" TextWrapping="Wrap"/>
                <ProgressBar Value="{Binding BackupProgress}" Height="12" Maximum="100"
                             Style="{StaticResource ModernProgressBar}"
                             Background="#1E293B" Foreground="{StaticResource AccentBrush}"/>
                <Grid Margin="0,8,0,0">
                    <TextBlock Text="{Binding BackupProgress, StringFormat={}{0:N0}%}"
                               Foreground="White" FontSize="13" FontWeight="Bold" HorizontalAlignment="Left"/>
                    <TextBlock Text="Vui lòng không tắt ứng dụng..."
                               Foreground="#94A3B8" FontSize="11" HorizontalAlignment="Right"/>
                </Grid>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
