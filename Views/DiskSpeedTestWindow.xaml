<Window x:Class="LapLapAutoTool.Views.DiskSpeedTestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Test Tốc Độ Ổ Cứng" Width="620" Height="480"
        WindowStartupLocation="CenterScreen"
        Background="#0F172A" ResizeMode="NoResize"
        Closed="Window_Closed">
    <Grid Margin="24,18,24,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="💿 Test Tốc Độ Ổ Cứng"
                   FontSize="22" FontWeight="Black" Foreground="White" Margin="0,0,0,4"/>
        <TextBlock Grid.Row="1" Text="Đo tốc độ đọc/ghi thực tế liên tục — cập nhật realtime"
                   FontSize="12" Foreground="#94A3B8" Margin="0,0,0,18"/>

        <!-- Settings row -->
        <Grid Grid.Row="2" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Kích thước test: " Foreground="#94A3B8" FontSize="12" VerticalAlignment="Center"/>
                <ComboBox x:Name="SizeCombo" SelectedIndex="1"
                          Background="#1E293B" Foreground="Black" BorderBrush="#334155"
                          FontSize="12" Padding="10,6" Width="110" Margin="8,0">
                    <ComboBox.ItemContainerStyle>
                        <Style TargetType="ComboBoxItem">
                            <Setter Property="Foreground" Value="Black"/>
                        </Style>
                    </ComboBox.ItemContainerStyle>
                    <ComboBoxItem Content="64 MB"/>
                    <ComboBoxItem Content="128 MB"/>
                    <ComboBoxItem Content="256 MB"/>
                    <ComboBoxItem Content="512 MB"/>
                </ComboBox>
                <TextBlock Text="Lặp liên tục: " Foreground="#94A3B8" FontSize="12" VerticalAlignment="Center"/>
                <CheckBox x:Name="LoopCheck" IsChecked="True" VerticalAlignment="Center"
                          Foreground="White" FontSize="12" Margin="8,0" Content="Bật"/>
            </StackPanel>
            <Button Grid.Column="1" x:Name="BtnStart" Content="▶ Bắt đầu" Click="StartTest"
                    Padding="18,9" Style="{StaticResource ModernButton}" FontSize="13" Margin="0,0,8,0"/>
            <Button Grid.Column="2" x:Name="BtnStop" Content="⏹ Dừng" Click="StopTest"
                    Padding="14,9" Style="{StaticResource SecondaryButton}" FontSize="13"
                    IsEnabled="False"/>
        </Grid>

        <!-- Speed meters -->
        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Current speeds -->
            <UniformGrid Grid.Row="0" Columns="2" Margin="0,0,0,14">
                <!-- Write speed -->
                <Border Background="#1E293B" CornerRadius="10" Padding="16,14" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="GHI (WRITE)" Foreground="#64748B" FontSize="10" FontWeight="Bold"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,6" VerticalAlignment="Center">
                            <TextBlock x:Name="WriteSpeedText" Text="—" FontSize="32" FontWeight="Black" Foreground="#F59E0B"/>
                            <TextBlock Text=" MB/s" FontSize="14" Foreground="#94A3B8" VerticalAlignment="Bottom" Margin="4,0,0,4"/>
                        </StackPanel>
                        <Border Background="#0F172A" CornerRadius="4" Height="12">
                            <Border x:Name="WriteBar" Background="#F59E0B" CornerRadius="4" HorizontalAlignment="Left" Width="0"/>
                        </Border>
                        <TextBlock x:Name="WriteMaxText" Text="Max: — MB/s" Foreground="#475569" FontSize="10" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Read speed -->
                <Border Background="#1E293B" CornerRadius="10" Padding="16,14" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="ĐỌC (READ)" Foreground="#64748B" FontSize="10" FontWeight="Bold"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,6" VerticalAlignment="Center">
                            <TextBlock x:Name="ReadSpeedText" Text="—" FontSize="32" FontWeight="Black" Foreground="#2563EB"/>
                            <TextBlock Text=" MB/s" FontSize="14" Foreground="#94A3B8" VerticalAlignment="Bottom" Margin="4,0,0,4"/>
                        </StackPanel>
                        <Border Background="#0F172A" CornerRadius="4" Height="12">
                            <Border x:Name="ReadBar" Background="#2563EB" CornerRadius="4" HorizontalAlignment="Left" Width="0"/>
                        </Border>
                        <TextBlock x:Name="ReadMaxText" Text="Max: — MB/s" Foreground="#475569" FontSize="10" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- History chart canvas -->
            <Border Grid.Row="1" Background="#0A0F1E" CornerRadius="8">
                <Grid>
                    <Canvas x:Name="ChartCanvas" ClipToBounds="True">
                        <Polyline x:Name="WriteChart" Stroke="#F59E0B" StrokeThickness="2" Opacity="0.8"/>
                        <Polyline x:Name="ReadChart"  Stroke="#2563EB" StrokeThickness="2" Opacity="0.8"/>
                    </Canvas>
                    <StackPanel VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,8,12,0">
                        <StackPanel Orientation="Horizontal">
                            <Rectangle Fill="#F59E0B" Width="16" Height="3" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="Write" Foreground="#F59E0B" FontSize="11"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <Rectangle Fill="#2563EB" Width="16" Height="3" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="Read" Foreground="#2563EB" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="4" Background="#1E293B" CornerRadius="6" Padding="12,7" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal">
                <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="#334155" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock x:Name="StatusText" Text="Sẵn sàng — nhấn Bắt đầu để test"
                           Foreground="#94A3B8" FontSize="12" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
