<Window x:Class="LapLapAutoTool.Views.TouchpadTestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Test Touchpad" Width="520" Height="460"
        WindowStartupLocation="CenterScreen"
        Background="#0F172A"
        ResizeMode="NoResize">
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="👆 Test Touchpad" FontSize="24" FontWeight="Black" Foreground="White" Margin="0,0,0,5"/>
        <TextBlock Grid.Row="1" Text="Di chuyển chuột trong vùng bên dưới để kiểm tra touchpad" FontSize="13" Foreground="#94A3B8" Margin="0,0,0,20"/>

        <!-- Touch Area -->
        <Border Grid.Row="2" Background="#1E293B" CornerRadius="12" BorderBrush="#334155" BorderThickness="1"
                MouseMove="TouchArea_MouseMove"
                MouseLeftButtonDown="TouchArea_MouseDown"
                MouseRightButtonDown="TouchArea_RightDown"
                MouseLeftButtonUp="TouchArea_MouseUp"
                MouseLeave="TouchArea_Leave"
                Margin="0,0,0,15">
            <Grid>
                <!-- Trail Canvas -->
                <Canvas x:Name="TrailCanvas" ClipToBounds="True"/>

                <!-- Cursor dot -->
                <Ellipse x:Name="CursorDot" Width="18" Height="18" Fill="#2563EB"
                         IsHitTestVisible="False" RenderTransformOrigin="0.5,0.5"
                         HorizontalAlignment="Left" VerticalAlignment="Top">
                    <Ellipse.RenderTransform>
                        <TranslateTransform x:Name="CursorTransform"/>
                    </Ellipse.RenderTransform>
                </Ellipse>

                <!-- Center hint -->
                <StackPanel x:Name="HintPanel" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False">
                    <TextBlock Text="Di chuyển chuột vào đây" Foreground="#334155" FontSize="16" HorizontalAlignment="Center"/>
                    <TextBlock Text="Click L / Click R để test nút" Foreground="#334155" FontSize="13" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Stats bar -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="#1E293B" CornerRadius="6" Padding="12,8" Margin="0,0,5,0">
                <StackPanel>
                    <TextBlock Text="VỊ TRÍ" Foreground="#64748B" FontSize="10" FontWeight="Bold"/>
                    <TextBlock x:Name="PosText" Text="X:0  Y:0" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Background="#1E293B" CornerRadius="6" Padding="12,8" Margin="5,0">
                <StackPanel>
                    <TextBlock Text="CLICK TRÁI" Foreground="#64748B" FontSize="10" FontWeight="Bold"/>
                    <TextBlock x:Name="LClickText" Text="0 lần" Foreground="#10B981" FontSize="12" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Background="#1E293B" CornerRadius="6" Padding="12,8" Margin="5,0">
                <StackPanel>
                    <TextBlock Text="CLICK PHẢI" Foreground="#64748B" FontSize="10" FontWeight="Bold"/>
                    <TextBlock x:Name="RClickText" Text="0 lần" Foreground="#F59E0B" FontSize="12" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>
            <Button Grid.Column="3" Content="Xóa" Click="Clear_Click"
                    Padding="15,0" Style="{StaticResource ModernButton}" FontSize="12"
                    Margin="5,0,0,0"/>
        </Grid>
    </Grid>
</Window>
