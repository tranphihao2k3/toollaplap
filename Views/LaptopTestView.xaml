<UserControl x:Class="LapLapAutoTool.Views.LaptopTestView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="900">

    <Grid Background="#070A10" Margin="20,16,20,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <Path Data="M21 2H3c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h7l-2 3v1h8v-1l-2-3h7c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H3V4h18v12z"
                  Fill="#00D2FF" Width="24" Height="24" Stretch="Uniform" Margin="0,0,10,0">
                <Path.Effect>
                    <DropShadowEffect Color="#00D2FF" BlurRadius="8" ShadowDepth="0" Opacity="0.4"/>
                </Path.Effect>
            </Path>
            <TextBlock Text="HARDWARE_DIAGNOSTICS"
                       FontSize="22" FontWeight="Black" Foreground="White"
                       FontFamily="Rajdhani, Consolas" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Tab Bar - compact -->
        <ItemsControl Grid.Row="1" ItemsSource="{Binding TestItems}" Margin="0,0,0,12">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Command="{Binding Command}" Cursor="Hand" Margin="0,0,6,6">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="TabBd" Background="#0B101A"
                                        CornerRadius="8" Padding="12,8"
                                        BorderBrush="{Binding AccentColor, Converter={StaticResource ColorToBrushConverter}}"
                                        BorderThickness="1">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="24" Height="24" CornerRadius="6"
                                                Background="{Binding AccentColor, Converter={StaticResource ColorToBrushConverter}}"
                                                Margin="0,0,8,0">
                                            <Path Data="{Binding IconData}"
                                                  Fill="White" Stretch="Uniform"
                                                  Width="12" Height="12"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Title}"
                                                       FontSize="12" FontWeight="ExtraBold" Foreground="White"
                                                       FontFamily="Rajdhani, Consolas"/>
                                            <TextBlock Text="{Binding Description}"
                                                       FontSize="9.5" Foreground="#64748B"
                                                       FontFamily="Rajdhani, Consolas"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="TabBd" Property="Background" Value="#162232"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Test Content Area -->
        <Border Grid.Row="2" Background="#0A0E16" CornerRadius="10"
                BorderBrush="#1E293B" BorderThickness="1">
            <Grid>
                <!-- Hint when no test selected -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="{Binding CurrentTestControl, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverse}">
                    <Path Data="M21 2H3c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h7l-2 3v1h8v-1l-2-3h7c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H3V4h18v12z"
                          Fill="#1E293B" Width="40" Height="40" Stretch="Uniform" Margin="0,0,0,12"/>
                    <TextBlock Text="Chọn một mục test ở trên"
                               FontSize="15" Foreground="#334155" FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               FontFamily="Rajdhani, Consolas"/>
                </StackPanel>

                <!-- Inline test control -->
                <ContentControl Content="{Binding CurrentTestControl}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
