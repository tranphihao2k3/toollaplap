<UserControl x:Class="LapLapAutoTool.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800"
             TextOptions.TextFormattingMode="Display"
             RenderOptions.ClearTypeHint="Enabled">
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="CÀI ĐẶT &amp; BẢN QUYỀN" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,20"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- License Info Card -->
                <Border Style="{StaticResource ModernCard}" Margin="0,0,0,20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="THÔNG TIN BẢN QUYỀN (LICENSE)" FontSize="14" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,15"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Mã License Key:" Foreground="{StaticResource MutedTextBrush}" Margin="0,5"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Token}" Foreground="White" FontWeight="SemiBold" Margin="0,5"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Tên khách hàng:" Foreground="{StaticResource MutedTextBrush}" Margin="0,5"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding CustomerName}" Foreground="White" FontWeight="SemiBold" Margin="0,5"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Số điện thoại:" Foreground="{StaticResource MutedTextBrush}" Margin="0,5"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding CustomerPhone}" Foreground="White" FontWeight="SemiBold" Margin="0,5"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Mã máy (HWID):" Foreground="{StaticResource MutedTextBrush}" Margin="0,5"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Hwid}" Foreground="White" FontWeight="SemiBold" Margin="0,5"/>
                    </Grid>
                </Border>

                <!-- Expiration Card -->
                <Border Style="{StaticResource ModernCard}" Margin="0,0,0,20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="THỜI HẠN SỬ DỤNG" FontSize="14" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,15"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Trạng thái:" Foreground="{StaticResource MutedTextBrush}" Margin="0,5"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Status}" Foreground="{StaticResource SuccessBrush}" FontWeight="SemiBold" Margin="0,5"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Ngày hết hạn:" Foreground="{StaticResource MutedTextBrush}" Margin="0,5"/>
                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,5">
                            <TextBlock Text="{Binding ExpiryDateString}" Foreground="White" FontWeight="SemiBold" Margin="0,0,10,0"/>
                            <Border Background="#334155" CornerRadius="4" Padding="5,2">
                                <TextBlock Text="{Binding DaysRemainingString}" Foreground="#FBBF24" FontSize="11" FontWeight="Bold"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Logout Button -->
                <Button Content="🚪 Đăng xuất bản quyền trên máy này" 
                        Command="{Binding LogoutCommand}"
                        Style="{StaticResource ModernButton}" 
                        Background="#DC2626" 
                        Foreground="White"
                        FontSize="14" 
                        FontWeight="Bold"
                        Padding="20,12"
                        Margin="0,20,0,0"
                        HorizontalAlignment="Left"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
