<UserControl x:Class="LapLapAutoTool.Views.QuickSetupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="900">

    <UserControl.Resources>
        <SolidColorBrush x:Key="CyanAc" Color="#00D2FF"/>
        <SolidColorBrush x:Key="PurpleAc" Color="#B25CFF"/>
        <SolidColorBrush x:Key="OrangeAc" Color="#FFB800"/>
        <SolidColorBrush x:Key="GreenAc" Color="#1ae65d"/>

        <!-- Row item template (reused DataTemplate) -->
        <DataTemplate x:Key="SoftwareRowTemplate">
            <Grid MinHeight="38">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#08FFFFFF"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="36"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="150"/>
                </Grid.ColumnDefinitions>

                <Border Grid.ColumnSpan="4" BorderBrush="#08FFFFFF" BorderThickness="0,0,0,1" VerticalAlignment="Bottom"/>

                <!-- Checkbox -->
                <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" IsHitTestVisible="False"
                          VerticalAlignment="Center" HorizontalAlignment="Center"/>

                <!-- Name + download progress -->
                <Grid Grid.Column="1" Margin="4,4,8,4" VerticalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Stroke" Value="#25FFFFFF"/>
                                    <Setter Property="StrokeThickness" Value="1.5"/>
                                    <Setter Property="Fill" Value="Transparent"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Status}" Value="Installing">
                                            <Setter Property="Stroke" Value="{StaticResource PrimaryBrush}"/>
                                            <Setter Property="StrokeDashArray" Value="3,1"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Status}" Value="Completed">
                                            <Setter Property="Fill" Value="{StaticResource SuccessBrush}"/>
                                            <Setter Property="Stroke" Value="{StaticResource SuccessBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Status}" Value="Failed">
                                            <Setter Property="Fill" Value="{StaticResource DangerBrush}"/>
                                            <Setter Property="Stroke" Value="{StaticResource DangerBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding DownloadStatus}" Value="Downloading">
                                            <Setter Property="Stroke" Value="#A855F7"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>

                        <TextBlock Text="{Binding Name}" FontSize="12.5" FontWeight="Bold" FontFamily="Rajdhani, Consolas"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="White"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Status}" Value="Completed">
                                            <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Status}" Value="Failed">
                                            <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding DownloadStatus}" Value="Downloading">
                                            <Setter Property="Foreground" Value="#A855F7"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <TextBlock Text="{Binding Description}" FontSize="10" Foreground="#4A7A8A"
                                   Margin="10,0,0,0" VerticalAlignment="Center" FontFamily="Consolas"/>
                    </StackPanel>

                    <!-- Download progress bar -->
                    <StackPanel Grid.Row="1" Margin="18,2,0,0"
                                Visibility="{Binding IsDownloading, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid Margin="0,0,0,1">
                            <TextBlock Text="{Binding DownloadStatusText}" FontSize="8.5"
                                       Foreground="{StaticResource MutedTextBrush}" FontFamily="Consolas"/>
                            <TextBlock Text="{Binding DownloadProgress, StringFormat='{}{0:0}%'}"
                                       FontSize="8.5" Foreground="#A855F7"
                                       HorizontalAlignment="Right" FontFamily="Consolas" FontWeight="Bold"/>
                        </Grid>
                        <ProgressBar Value="{Binding DownloadProgress}" Maximum="100" Height="2"
                                     Foreground="#A855F7" Background="#10FFFFFF"
                                     BorderThickness="0" Style="{StaticResource ModernProgressBar}"/>
                    </StackPanel>
                </Grid>

                <!-- Size -->
                <TextBlock Grid.Column="2" Text="{Binding FileSize}" VerticalAlignment="Center"
                           FontSize="10" FontFamily="Consolas" Foreground="#4A7A8A"/>

                <!-- Status -->
                <TextBlock Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Right"
                           FontSize="10" FontFamily="Consolas" FontWeight="Bold" Margin="0,0,6,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="Queued"/>
                            <Setter Property="Foreground" Value="#334155"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Status}" Value="Installing">
                                    <Setter Property="Text" Value="Installing..."/>
                                    <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding DownloadStatus}" Value="Downloading">
                                    <Setter Property="Text" Value="Downloading..."/>
                                    <Setter Property="Foreground" Value="#A855F7"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="Completed">
                                    <Setter Property="Text" Value="Installed"/>
                                    <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="Failed">
                                    <Setter Property="Text" Value="Failed"/>
                                    <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Row click overlay -->
                <ToggleButton Grid.ColumnSpan="4" IsChecked="{Binding IsSelected}" Cursor="Hand">
                    <ToggleButton.Template>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border Background="Transparent"/>
                        </ControlTemplate>
                    </ToggleButton.Template>
                </ToggleButton>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===== HEADER ===== -->
        <Border Grid.Row="0" Background="#0A0C12" BorderBrush="#1500F2FF" BorderThickness="0,0,0,1" Padding="24,16">
            <Grid>
                <StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,3">
                        <Path Data="M5,20H19V18H5M19,9H15V3H9V9H5L12,16L19,9Z"
                              Fill="{StaticResource PrimaryBrush}" Width="20" Height="20" Stretch="Uniform" Margin="0,0,10,0"/>
                        <TextBlock Text="AUTO_DEPLOYMENT" FontSize="22" Foreground="White" FontWeight="Black"
                                   FontFamily="Rajdhani, Consolas"/>
                    </StackPanel>
                    <TextBlock FontSize="11" Foreground="{StaticResource PrimaryBrush}" FontFamily="Consolas" Opacity="0.7"
                               Text="Batch Silent Installer • software_config.json"/>
                </StackPanel>

                <!-- Action Buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="SELECT_ALL" Command="{Binding SelectAllCommand}"
                            FontFamily="Consolas" FontSize="10" FontWeight="Bold"
                            Padding="12,6" Margin="0,0,8,0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="Transparent"
                                        BorderBrush="#30FFFFFF" BorderThickness="1" CornerRadius="3"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#12FFFFFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.Foreground>
                            <SolidColorBrush Color="#64748B"/>
                        </Button.Foreground>
                    </Button>

                    <Button Content="DESELECT" Command="{Binding SelectNoneCommand}"
                            FontFamily="Consolas" FontSize="10" FontWeight="Bold"
                            Padding="12,6" Margin="0,0,8,0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="Transparent"
                                        BorderBrush="#30FFFFFF" BorderThickness="1" CornerRadius="3"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#12FFFFFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.Foreground>
                            <SolidColorBrush Color="#64748B"/>
                        </Button.Foreground>
                    </Button>

                    <Button Command="{Binding StartInstallCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}"
                            FontFamily="Consolas" FontSize="10" FontWeight="Bold"
                            Padding="14,6" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd2" BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="1"
                                        CornerRadius="3" Padding="{TemplateBinding Padding}" Background="#1200F2FF">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="5" Height="5" Fill="{StaticResource PrimaryBrush}" Margin="0,0,7,0" VerticalAlignment="Center"/>
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Opacity" Value="0.7"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd2" Property="Background">
                                            <Setter.Value><SolidColorBrush Color="#2000F2FF"/></Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock FontFamily="Consolas" FontSize="10" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="DEPLOYING..."/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsBusy}" Value="False">
                                            <Setter Property="Text" Value="DEPLOY_ALL"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== GLOBAL PROGRESS ===== -->
        <Grid Grid.Row="1" Margin="24,10,24,0">
            <Border Background="#0800F2FF" BorderBrush="#1800F2FF" BorderThickness="1" CornerRadius="2" Padding="10,5">
                <Grid>
                    <TextBlock Text="{Binding StatusText}" FontSize="10" FontFamily="Consolas" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Progress, StringFormat='{}{0:0}%'}"
                               FontSize="10" FontFamily="Consolas" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Right"/>
                </Grid>
            </Border>
            <ProgressBar Value="{Binding Progress}" Maximum="100" Height="2"
                         Foreground="{StaticResource PrimaryBrush}" Background="Transparent"
                         BorderThickness="0" VerticalAlignment="Bottom"
                         Style="{StaticResource ModernProgressBar}"/>
        </Grid>

        <!-- ===== GROUPED SOFTWARE LIST ===== -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="24,10,24,14">
            <StackPanel>

                <!-- ══ PHẦN MỀM CƠ BẢN (Windows Essentials) ══ -->
                <Border Background="#0B101A" CornerRadius="8" BorderBrush="#1A00D2FF" BorderThickness="1"
                        Margin="0,0,0,12">
                    <StackPanel>
                        <!-- Section Header -->
                        <Border Background="#0D1520" CornerRadius="8,8,0,0" Padding="14,10"
                                BorderBrush="#1A00D2FF" BorderThickness="0,0,0,1">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="22" Height="22" CornerRadius="5" Background="#1A00D2FF" Margin="0,0,10,0">
                                    <Path Data="M3,12V6.75L9,5.43V11.91L3,12M20,3V11.75L10,11.9V5.21L20,3M3,13L9,13.09V19.9L3,18.75V13M10,13.1L20,13.25V22L10,20.09V13.1Z"
                                          Fill="#00D2FF" Width="12" Height="12" Stretch="Uniform"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="PHẦN MỀM CƠ BẢN" FontSize="12" FontWeight="ExtraBold"
                                           Foreground="#00D2FF" FontFamily="Rajdhani, Consolas" VerticalAlignment="Center"/>
                                <TextBlock Text=" — Windows Essentials" FontSize="10" Foreground="#4A7A8A"
                                           FontFamily="Consolas" VerticalAlignment="Center" Margin="6,0,0,0"/>
                            </StackPanel>
                        </Border>
                        <!-- Items -->
                        <ItemsControl ItemsSource="{Binding SoftwareList}"
                                      ItemTemplate="{StaticResource SoftwareRowTemplate}"
                                      Margin="4,2,4,4"/>
                    </StackPanel>
                </Border>

                <!-- ══ TIỆN ÍCH (Utilities) ══ -->
                <Border Background="#0B101A" CornerRadius="8" BorderBrush="#1AB25CFF" BorderThickness="1"
                        Margin="0,0,0,12">
                    <StackPanel>
                        <Border Background="#0D1220" CornerRadius="8,8,0,0" Padding="14,10"
                                BorderBrush="#1AB25CFF" BorderThickness="0,0,0,1">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="22" Height="22" CornerRadius="5" Background="#1AB25CFF" Margin="0,0,10,0">
                                    <Path Data="M22.7,19L13.6,9.9C14.5,7.6 14,4.9 12.1,3C10.1,1 7.1,0.6 4.7,1.7L8.5,5.5L5.5,8.5L1.7,4.7C0.6,7.1 1,10.1 3,12.1C4.9,14 7.6,14.5 9.9,13.6L19,22.7C19.4,23.1 20,23.1 20.4,22.7L22.7,20.4C23.1,20 23.1,19.4 22.7,19Z"
                                          Fill="#B25CFF" Width="12" Height="12" Stretch="Uniform"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="TIỆN ÍCH" FontSize="12" FontWeight="ExtraBold"
                                           Foreground="#B25CFF" FontFamily="Rajdhani, Consolas" VerticalAlignment="Center"/>
                                <TextBlock Text=" — System Utilities" FontSize="10" Foreground="#4A7A8A"
                                           FontFamily="Consolas" VerticalAlignment="Center" Margin="6,0,0,0"/>
                            </StackPanel>
                        </Border>
                        <ItemsControl ItemsSource="{Binding UtilityList}"
                                      ItemTemplate="{StaticResource SoftwareRowTemplate}"
                                      Margin="4,2,4,4"/>
                    </StackPanel>
                </Border>

                <!-- ══ GAME ══ -->
                <Border Background="#0B101A" CornerRadius="8" BorderBrush="#1AFFB800" BorderThickness="1"
                        Margin="0,0,0,4">
                    <StackPanel>
                        <Border Background="#12150D" CornerRadius="8,8,0,0" Padding="14,10"
                                BorderBrush="#1AFFB800" BorderThickness="0,0,0,1">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="22" Height="22" CornerRadius="5" Background="#1AFFB800" Margin="0,0,10,0">
                                    <Path Data="M21,6H3A2,2 0 0,0 1,8V16A2,2 0 0,0 3,18H21A2,2 0 0,0 23,16V8A2,2 0 0,0 21,6M11,13H8V16H6V13H3V11H6V8H8V11H11V13M15.5,15A1.5,1.5 0 0,1 14,13.5A1.5,1.5 0 0,1 15.5,12A1.5,1.5 0 0,1 17,13.5A1.5,1.5 0 0,1 15.5,15M19.5,12A1.5,1.5 0 0,1 18,10.5A1.5,1.5 0 0,1 19.5,9A1.5,1.5 0 0,1 21,10.5A1.5,1.5 0 0,1 19.5,12Z"
                                          Fill="#FFB800" Width="12" Height="12" Stretch="Uniform"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="GAME" FontSize="12" FontWeight="ExtraBold"
                                           Foreground="#FFB800" FontFamily="Rajdhani, Consolas" VerticalAlignment="Center"/>
                                <TextBlock Text=" — Gaming &amp; Entertainment" FontSize="10" Foreground="#4A7A8A"
                                           FontFamily="Consolas" VerticalAlignment="Center" Margin="6,0,0,0"/>
                            </StackPanel>
                        </Border>
                        <ItemsControl ItemsSource="{Binding GameList}"
                                      ItemTemplate="{StaticResource SoftwareRowTemplate}"
                                      Margin="4,2,4,4"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
