<UserControl x:Class="LapLapAutoTool.Views.StudentAppsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:models="clr-namespace:LapLapAutoTool.Models"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Phần mềm Sinh viên" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                <TextBlock Text="Chọn phiên bản cần tải — tự động giải nén và mở thư mục" Foreground="{StaticResource MutedTextBrush}" FontSize="14"/>
            </StackPanel>
        </Grid>

        <!-- Danh sách nhóm phần mềm -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding AppGroups}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- Card mỗi nhóm phần mềm -->
                        <Border Style="{StaticResource ModernCard}" Margin="0,0,0,12" Padding="0">
                            <StackPanel>

                                <!-- Header nhóm -->
                                <Border Background="#0F172A" CornerRadius="12,12,0,0" Padding="16,12">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Background="{StaticResource PrimaryBrush}" CornerRadius="6" Width="32" Height="24" Margin="0,0,10,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Icon}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Foreground="White" FontFamily="Segoe UI"/>
                                        </Border>
                                        <TextBlock Text="{Binding Group}" FontSize="15" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <!-- Danh sách phiên bản -->
                                <ItemsControl ItemsSource="{Binding Versions}" Margin="0,4,0,8">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="16,8,16,8">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#0F172A"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Badge năm -->
                                                    <Border Grid.Column="0" CornerRadius="6" Padding="10,3" Margin="0,0,12,0" VerticalAlignment="Center">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="#1E293B"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding DownloadStatus}" Value="{x:Static models:DownloadStatus.Done}">
                                                                        <Setter Property="Background" Value="#064E3B"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="{Binding Year}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding DownloadStatus}" Value="{x:Static models:DownloadStatus.Done}">
                                                                            <Setter Property="Foreground" Value="#10B981"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Border>

                                                    <!-- Tên + progress -->
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}" FontSize="13" Foreground="White"/>

                                                        <!-- Progress bar (chỉ hiện khi đang tải) -->
                                                        <StackPanel Margin="0,6,0,0" Visibility="{Binding IsDownloading, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                            <Grid Margin="0,0,0,4">
                                                                <TextBlock Text="{Binding DownloadStatusText}" FontSize="10" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Left"/>
                                                                <TextBlock Text="{Binding DownloadProgress, StringFormat='{}{0:0}%'}" FontSize="10" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Right"/>
                                                            </Grid>
                                                            <ProgressBar Value="{Binding DownloadProgress}" Maximum="100" Height="3"
                                                                         Background="#334155" Foreground="{StaticResource AccentBrush}" BorderThickness="0"/>
                                                        </StackPanel>

                                                        <!-- Text hoàn tất -->
                                                        <TextBlock Text="{Binding DownloadStatusText}" FontSize="10" Foreground="#10B981" Margin="0,4,0,0"
                                                                   Visibility="{Binding DownloadStatus, Converter={StaticResource DownloadDoneVisibilityConverter}}"/>
                                                    </StackPanel>

                                                    <!-- File size badge -->
                                                    <Border Grid.Column="2" CornerRadius="4" Padding="8,3" Margin="10,0" VerticalAlignment="Center"
                                                            Background="#0F172A"
                                                            Visibility="{Binding FileSize, Converter={StaticResource StringToVisibilityConverter}}">
                                                        <TextBlock Text="{Binding FileSize}" FontSize="11" Foreground="{StaticResource MutedTextBrush}"/>
                                                    </Border>

                                                    <!-- Nút tải / trạng thái -->
                                                    <StackPanel Grid.Column="3" VerticalAlignment="Center">

                                                        <!-- Nút Tải về -->
                                                        <Button Padding="16,6" Tag="{Binding}" Click="DownloadButton_Click"
                                                                FontSize="12" FontWeight="SemiBold">
                                                            <Button.Visibility>
                                                                <MultiBinding Converter="{StaticResource DownloadIdleVisibilityConverter}">
                                                                    <Binding Path="DownloadStatus"/>
                                                                    <Binding Path="DownloadUrl"/>
                                                                </MultiBinding>
                                                            </Button.Visibility>
                                                            <Button.Style>
                                                                <Style TargetType="Button" BasedOn="{StaticResource ModernButton}">
                                                                    <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding DownloadUrl}" Value="">
                                                                            <Setter Property="Background" Value="#334155"/>
                                                                            <Setter Property="IsEnabled" Value="False"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Button.Style>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="⬇  " FontSize="12"/>
                                                                <TextBlock FontSize="12">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Text" Value="Tải về"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding DownloadUrl}" Value="">
                                                                                    <Setter Property="Text" Value="Chưa có"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </StackPanel>
                                                        </Button>

                                                        <!-- Đang tải -->
                                                        <Border Background="#1E3A5F" CornerRadius="8" Padding="12,6"
                                                                Visibility="{Binding IsDownloading, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                            <TextBlock FontSize="12" Foreground="{StaticResource AccentBrush}">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Text" Value="⏳  Đang tải"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding DownloadStatus}" Value="{x:Static models:DownloadStatus.Extracting}">
                                                                                <Setter Property="Text" Value="📦  Giải nén"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Border>

                                                        <!-- Hoàn tất -->
                                                        <Border Background="#064E3B" CornerRadius="8" Padding="12,6"
                                                                Visibility="{Binding DownloadStatus, Converter={StaticResource DownloadDoneVisibilityConverter}}">
                                                            <TextBlock Text="✅  Đã tải" FontSize="12" Foreground="#10B981" FontWeight="Bold"/>
                                                        </Border>

                                                        <!-- Lỗi -->
                                                        <Border Background="#450A0A" CornerRadius="8" Padding="12,6"
                                                                Visibility="{Binding DownloadStatus, Converter={StaticResource DownloadFailedVisibilityConverter}}">
                                                            <TextBlock Text="❌  Lỗi" FontSize="12" Foreground="#EF4444" FontWeight="Bold"/>
                                                        </Border>

                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
