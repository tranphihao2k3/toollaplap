<UserControl x:Class="LapLapAutoTool.Views.StudentAppsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:models="clr-namespace:LapLapAutoTool.Models"
             mc:Ignorable="d">
    <Grid Margin="18,14,18,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,14">
            <StackPanel>
                <TextBlock Text="Phần mềm Sinh viên" FontSize="22" FontWeight="Black" Foreground="White"/>
                <TextBlock Text="Chọn phiên bản cần tải — tự động giải nén và mở thư mục"
                           Foreground="{StaticResource MutedTextBrush}" FontSize="13"/>
            </StackPanel>
        </Grid>

        <!-- 2-column group grid -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding AppGroups}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="2"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- Card per group, ~half width -->
                        <Border Style="{StaticResource ModernCard}" VerticalAlignment="Top"
                                Margin="0,0,12,12" Padding="0">
                            <StackPanel>
                                <!-- Group header -->
                                <Border Background="#0F172A" CornerRadius="12,12,0,0" Padding="14,10">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Background="{StaticResource PrimaryBrush}" CornerRadius="5"
                                                Width="28" Height="20" Margin="0,0,10,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Icon}" FontSize="10" FontWeight="Bold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Foreground="White" FontFamily="Segoe UI"/>
                                        </Border>
                                        <TextBlock Text="{Binding Group}" FontSize="14" FontWeight="Bold"
                                                   Foreground="White" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <!-- Version list (compact rows) -->
                                <ItemsControl ItemsSource="{Binding Versions}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="14,7,14,7">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#0F172A"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Year badge -->
                                                    <Border Grid.Column="0" CornerRadius="5" Padding="8,2" Margin="0,0,10,0" VerticalAlignment="Center">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="#1E293B"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding DownloadStatus}" Value="{x:Static models:DownloadStatus.Done}">
                                                                        <Setter Property="Background" Value="#064E3B"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="{Binding Year}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding DownloadStatus}" Value="{x:Static models:DownloadStatus.Done}">
                                                                            <Setter Property="Foreground" Value="#10B981"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Border>

                                                    <!-- Name + progress -->
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}" FontSize="12" Foreground="White" TextTrimming="CharacterEllipsis"/>
                                                        <StackPanel Margin="0,4,0,0"
                                                                    Visibility="{Binding IsDownloading, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                            <ProgressBar Value="{Binding DownloadProgress}" Maximum="100"
                                                                         Height="3" Background="#334155"
                                                                         Foreground="{StaticResource AccentBrush}" BorderThickness="0"/>
                                                            <TextBlock Text="{Binding DownloadProgress, StringFormat='{}{0:0}%'}"
                                                                       FontSize="9" Foreground="{StaticResource MutedTextBrush}"/>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding DownloadStatusText}" FontSize="10" Foreground="#10B981"
                                                                   Visibility="{Binding DownloadStatus, Converter={StaticResource DownloadDoneVisibilityConverter}}"/>
                                                    </StackPanel>

                                                    <!-- Size badge -->
                                                    <Border Grid.Column="2" CornerRadius="4" Padding="6,2" Margin="6,0" VerticalAlignment="Center"
                                                            Background="#0F172A"
                                                            Visibility="{Binding FileSize, Converter={StaticResource StringToVisibilityConverter}}">
                                                        <TextBlock Text="{Binding FileSize}" FontSize="10" Foreground="{StaticResource MutedTextBrush}"/>
                                                    </Border>

                                                    <!-- Action buttons -->
                                                    <StackPanel Grid.Column="3" VerticalAlignment="Center">
                                                        <Button Padding="12,5" Tag="{Binding}" Click="DownloadButton_Click"
                                                                FontSize="11" FontWeight="SemiBold">
                                                            <Button.Visibility>
                                                                <MultiBinding Converter="{StaticResource DownloadIdleVisibilityConverter}">
                                                                    <Binding Path="DownloadStatus"/>
                                                                    <Binding Path="DownloadUrl"/>
                                                                </MultiBinding>
                                                            </Button.Visibility>
                                                            <Button.Style>
                                                                <Style TargetType="Button" BasedOn="{StaticResource ModernButton}">
                                                                    <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding DownloadUrl}" Value="">
                                                                            <Setter Property="Background" Value="#334155"/>
                                                                            <Setter Property="IsEnabled" Value="False"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Button.Style>
                                                            <TextBlock FontSize="11">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Text" Value="⬇ Tải"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding DownloadUrl}" Value="">
                                                                                <Setter Property="Text" Value="—"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Button>
                                                        <Border Background="#1E3A5F" CornerRadius="6" Padding="10,5"
                                                                Visibility="{Binding IsDownloading, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                            <TextBlock Text="⏳" FontSize="12" Foreground="{StaticResource AccentBrush}"/>
                                                        </Border>
                                                        <Border Background="#064E3B" CornerRadius="6" Padding="10,5"
                                                                Visibility="{Binding DownloadStatus, Converter={StaticResource DownloadDoneVisibilityConverter}}">
                                                            <TextBlock Text="✅" FontSize="12" Foreground="#10B981"/>
                                                        </Border>
                                                        <Border Background="#450A0A" CornerRadius="6" Padding="10,5"
                                                                Visibility="{Binding DownloadStatus, Converter={StaticResource DownloadFailedVisibilityConverter}}">
                                                            <TextBlock Text="❌" FontSize="12" Foreground="#EF4444"/>
                                                        </Border>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
