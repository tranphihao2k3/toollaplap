<UserControl x:Class="LapLapAutoTool.Views.HardwareView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignWidth="1200" d:DesignHeight="800">

    <UserControl.Resources>
        <SolidColorBrush x:Key="AppBgBrush"      Color="#070A10"/>
        <SolidColorBrush x:Key="CardBgBrush"     Color="#0B101A"/>
        <SolidColorBrush x:Key="CardBorderBrush" Color="#1E293B"/>
        <SolidColorBrush x:Key="MutedText"       Color="#64748B"/>
        <SolidColorBrush x:Key="CyanAccent"      Color="#00D2FF"/>
        <SolidColorBrush x:Key="PurpleAccent"    Color="#B25CFF"/>
        <SolidColorBrush x:Key="PinkAccent"      Color="#F052B6"/>
        <SolidColorBrush x:Key="GreenAccent"     Color="#1ae65d"/>
        <SolidColorBrush x:Key="MetricLabelBrush" Color="#7aadb8"/>
        <SolidColorBrush x:Key="OrangeAccent"    Color="#FFB800"/>
        <SolidColorBrush x:Key="DangerAccent"    Color="#EF4444"/>
        <SolidColorBrush x:Key="ProgBg"          Color="#1A2436"/>

        <!-- Neon Glow Card Styles (subtle) -->
        <Style x:Key="GlowCardCyan" TargetType="Border">
            <Setter Property="Background" Value="#0B101A"/>
            <Setter Property="BorderBrush" Value="#3500D2FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#00D2FF" BlurRadius="10" ShadowDepth="0" Opacity="0.2"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Panel.ZIndex" Value="100"/>
                    <Setter Property="Background" Value="#162232"/>
                    <Setter Property="BorderBrush" Value="#AA00D2FF"/>
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.015" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.015" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GlowCardPurple" TargetType="Border">
            <Setter Property="Background" Value="#0B101A"/>
            <Setter Property="BorderBrush" Value="#35B25CFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#B25CFF" BlurRadius="10" ShadowDepth="0" Opacity="0.2"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Panel.ZIndex" Value="100"/>
                    <Setter Property="Background" Value="#1E1430"/>
                    <Setter Property="BorderBrush" Value="#AAB25CFF"/>
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.015" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.015" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GlowCardPink" TargetType="Border">
            <Setter Property="Background" Value="#0B101A"/>
            <Setter Property="BorderBrush" Value="#35F052B6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#F052B6" BlurRadius="10" ShadowDepth="0" Opacity="0.2"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Panel.ZIndex" Value="100"/>
                    <Setter Property="Background" Value="#2D1425"/>
                    <Setter Property="BorderBrush" Value="#AAF052B6"/>
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.015" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.015" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GlowCardGreen" TargetType="Border">
            <Setter Property="Background" Value="#0B101A"/>
            <Setter Property="BorderBrush" Value="#351ae65d"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#1ae65d" BlurRadius="10" ShadowDepth="0" Opacity="0.2"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Panel.ZIndex" Value="100"/>
                    <Setter Property="Background" Value="#0F2818"/>
                    <Setter Property="BorderBrush" Value="#AA1ae65d"/>
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.015" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.015" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GlowCardOrange" TargetType="Border">
            <Setter Property="Background" Value="#0B101A"/>
            <Setter Property="BorderBrush" Value="#35FFB800"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#FFB800" BlurRadius="10" ShadowDepth="0" Opacity="0.2"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Panel.ZIndex" Value="100"/>
                    <Setter Property="Background" Value="#2A2215"/>
                    <Setter Property="BorderBrush" Value="#AAFFB800"/>
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.015" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.015" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MetricLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MetricLabelBrush}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}}" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MutedLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedText}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}}" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FlatBar" TargetType="ProgressBar">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{StaticResource ProgBg}" CornerRadius="3" Height="{TemplateBinding Height}">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" BlurRadius="4" ShadowDepth="0" Opacity="0.3"/>
                            </Border.Effect>
                            <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}"
                                    HorizontalAlignment="Left" CornerRadius="3"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Background="{StaticResource AppBgBrush}" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===== HEADER ===== -->
        <Grid Grid.Row="0" Margin="0,0,0,25">
            <StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Path Data="M4,4H20V20H4V4M6,6V18H18V6H6M10,10H14V14H10V10M8,8H16V16H8V8Z"
                          Fill="{StaticResource CyanAccent}" Width="26" Height="26" Stretch="Uniform" Margin="0,0,12,0">
                        <Path.Effect>
                            <DropShadowEffect Color="#00D2FF" BlurRadius="5" ShadowDepth="0" Opacity="0.3"/>
                        </Path.Effect>
                    </Path>
                    <TextBlock Text="SYSTEM_DIAGNOSTICS" FontSize="26" Foreground="White" FontWeight="Bold"
                               FontFamily="Rajdhani, Consolas">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#00D2FF" BlurRadius="4" ShadowDepth="0" Opacity="0.15"/>
                        </TextBlock.Effect>
                    </TextBlock>
                </StackPanel>
                <TextBlock Text="{Binding SysInfo.ModelName, FallbackValue='Đang quét...'}"
                           Foreground="{StaticResource CyanAccent}" FontSize="14" Margin="0,5,0,0" FontWeight="SemiBold"
                           Opacity="0.9" FontFamily="Rajdhani, Consolas"/>
            </StackPanel>

            <!-- Rescan Button with Neon Glow -->
            <Button Command="{Binding LoadInfoCommand}" HorizontalAlignment="Right" VerticalAlignment="Center" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder" BorderBrush="#5500D2FF" BorderThickness="1.2"
                                Background="#0A1828" CornerRadius="6" Padding="20,10">
                            <Border.Effect>
                                <DropShadowEffect Color="#00D2FF" BlurRadius="6" ShadowDepth="0" Opacity="0.18"/>
                            </Border.Effect>
                            <TextBlock Text="∿ QUÉT LẠI PHẦN CỨNG" Foreground="{StaticResource CyanAccent}"
                                       FontFamily="Rajdhani, Consolas" FontSize="14" FontWeight="ExtraBold"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#2200D2FF"/>
                                <Setter TargetName="BtnBorder" Property="BorderBrush" Value="#AA00D2FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <!-- ===== DASHBOARD GRID ===== -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,10,0">
            <Grid Margin="10,10,10,20" ClipToBounds="False">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- ===== 0. SYSTEM INFO ===== -->
                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource GlowCardCyan}" Margin="0,0,0,20">
                    <StackPanel Margin="18">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Width="3" Height="18" CornerRadius="2" Background="{StaticResource CyanAccent}" Margin="0,0,8,0" VerticalAlignment="Center">
                                <Border.Effect>
                                    <DropShadowEffect Color="#00D2FF" BlurRadius="4" ShadowDepth="0" Opacity="0.3"/>
                                </Border.Effect>
                            </Border>
                            <TextBlock Text="THÔNG TIN HỆ THỐNG" FontSize="15" FontWeight="ExtraBold"
                                       Foreground="{StaticResource CyanAccent}" FontFamily="Rajdhani, Consolas">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="#00D2FF" BlurRadius="3" ShadowDepth="0" Opacity="0.12"/>
                                </TextBlock.Effect>
                            </TextBlock>
                        </StackPanel>

                        <!-- Model Name large -->
                        <TextBlock Text="{Binding SysInfo.ModelName, FallbackValue='Lenovo IdeaPad Gaming 3 15ARH7'}"
                                   FontSize="24" Foreground="White" FontWeight="Bold"
                                   FontFamily="Rajdhani, Consolas" Margin="0,0,0,14"/>

                        <!-- Info Grid -->
                        <UniformGrid Columns="3" Margin="0,0,0,0">
                            <StackPanel Margin="0,0,16,0">
                                <TextBlock Text="MAINBOARD" Style="{StaticResource MetricLabelStyle}"
                                           FontSize="11" FontWeight="ExtraBold" FontFamily="Consolas"/>
                                <TextBlock Text="{Binding SysInfo.Mainboard, FallbackValue='Lenovo LNVNB161216'}"
                                           FontSize="13.5" Foreground="White" FontWeight="SemiBold"
                                           FontFamily="Rajdhani, Consolas" Margin="0,3,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,16,0">
                                <TextBlock Text="SỐ SÊ-RI" Style="{StaticResource MetricLabelStyle}"
                                           FontSize="11" FontWeight="ExtraBold" FontFamily="Consolas"/>
                                <Button Command="{Binding CopySerialCommand}" Cursor="Hand" ToolTip="Click để sao chép số Serial">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <TextBlock Text="{Binding SysInfo.SerialNumber, FallbackValue='PF3XXXXX'}"
                                                   FontSize="13.5" Foreground="White" FontWeight="SemiBold"
                                                   FontFamily="Rajdhani, Consolas" Margin="0,3,0,0"/>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="BIOS" Style="{StaticResource MetricLabelStyle}"
                                           FontSize="11" FontWeight="ExtraBold" FontFamily="Consolas"/>
                                <TextBlock Text="{Binding SysInfo.BiosVersion, FallbackValue='LENOVO - 1'}"
                                           FontSize="13.5" Foreground="White" FontWeight="SemiBold"
                                           FontFamily="Rajdhani, Consolas" Margin="0,3,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Border>
               
                <!-- ===== 1. CPU ===== -->
                <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource GlowCardCyan}" Margin="0,0,0,20">
                    <Grid Margin="20">
                        <StackPanel>
                            <!-- Section title with neon bar -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Border Width="3" Height="18" CornerRadius="2" Background="{StaticResource CyanAccent}" Margin="0,0,8,0" VerticalAlignment="Center">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#00D2FF" BlurRadius="4" ShadowDepth="0" Opacity="0.3"/>
                                    </Border.Effect>
                                </Border>
                                <TextBlock Text="BỘ VI XỬ LÝ (CPU)" FontSize="15" FontWeight="ExtraBold"
                                           Foreground="{StaticResource CyanAccent}" FontFamily="Rajdhani, Consolas">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="#00D2FF" BlurRadius="3" ShadowDepth="0" Opacity="0.12"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                            </StackPanel>

                            <TextBlock Text="{Binding SysInfo.CPU, FallbackValue='Intel Core i7-13700H'}"
                                       FontSize="22" Foreground="White" FontWeight="Bold"
                                       TextWrapping="Wrap" FontFamily="Rajdhani, Consolas"/>
                            <TextBlock Text="{Binding SysInfo.CPUCoresThreads, StringFormat='{}{0} @ 2.40 GHz', FallbackValue='14 Cores, 20 Threads @ 2.40 GHz'}"
                                       FontSize="15" Style="{StaticResource MutedLabelStyle}" Margin="0,4,0,0" 
                                       FontFamily="Rajdhani, Consolas" FontWeight="Bold"/>

                            <Grid Margin="0,22,0,0">
                                <TextBlock Text="Mức sử dụng" Style="{StaticResource MetricLabelStyle}" FontSize="13.5" FontWeight="SemiBold" FontFamily="Rajdhani, Consolas"/>
                                <TextBlock Text="{Binding CpuLoadText, FallbackValue='12%'}" Foreground="{StaticResource CyanAccent}"
                                           HorizontalAlignment="Right" FontSize="14" FontWeight="ExtraBold" FontFamily="Rajdhani, Consolas"/>
                            </Grid>
                            <ProgressBar Margin="0,6,0,0" Height="5" Value="{Binding CpuLoad, FallbackValue=12}"
                                         Maximum="100" Foreground="{StaticResource CyanAccent}" Style="{StaticResource FlatBar}"/>

                            <Grid Margin="0,14,0,0">
                                <TextBlock Text="Nhiệt độ" Style="{StaticResource MetricLabelStyle}" FontSize="13.5" FontWeight="SemiBold" FontFamily="Rajdhani, Consolas"/>
                                <TextBlock Text="{Binding CpuTempText, FallbackValue='45°C'}" Foreground="{StaticResource OrangeAccent}"
                                           HorizontalAlignment="Right" FontSize="14" FontWeight="ExtraBold" FontFamily="Rajdhani, Consolas"/>
                            </Grid>
                            <ProgressBar Margin="0,6,0,0" Height="5" Value="{Binding CpuTemp, FallbackValue=45}"
                                         Maximum="100" Foreground="{StaticResource OrangeAccent}" Style="{StaticResource FlatBar}"/>
                        </StackPanel>

                        <!-- CPU Icon with glow -->
                        <Path Data="M6,6V18H18V6H6M8,8H16V16H8V8M10,10H14V14H10V10 M12,2V4 M8,2V4 M16,2V4 M12,20V22 M8,20V22 M16,20V22 M2,12H4 M2,8H4 M2,16H4 M20,12H22 M20,8H22 M20,16H22"
                              Fill="{StaticResource CyanAccent}" Width="65" Height="65" Stretch="Uniform"
                              HorizontalAlignment="Right" VerticalAlignment="Top" Opacity="0.08">
                            <Path.Effect>
                                <BlurEffect Radius="3"/>
                            </Path.Effect>
                        </Path>
                    </Grid>
                </Border>

                
                <!-- ===== 2. RAM ===== -->
                <Border Grid.Row="0" Grid.Column="4" Style="{StaticResource GlowCardPurple}" Margin="0,0,0,20">
                    <Grid Margin="20">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Border Width="3" Height="18" CornerRadius="2" Background="{StaticResource PurpleAccent}" Margin="0,0,8,0" VerticalAlignment="Center">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#B25CFF" BlurRadius="4" ShadowDepth="0" Opacity="0.3"/>
                                    </Border.Effect>
                                </Border>
                                <TextBlock Text="BỘ NHỚ (RAM)" FontSize="15" FontWeight="ExtraBold"
                                           Foreground="{StaticResource PurpleAccent}" FontFamily="Rajdhani, Consolas">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="#B25CFF" BlurRadius="3" ShadowDepth="0" Opacity="0.12"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                            </StackPanel>

                            <TextBlock Text="{Binding SysInfo.TotalRam, StringFormat='{}{0} DDR5', FallbackValue='16.0 GB DDR5'}"
                                       FontSize="22" Foreground="White" FontWeight="Bold" FontFamily="Rajdhani, Consolas"/>
                            <TextBlock FontSize="14" Style="{StaticResource MutedLabelStyle}" Margin="0,4,0,0" FontFamily="Rajdhani, Consolas" FontWeight="Bold">
                                <Run Text="{Binding SysInfo.RamSticks[0].Manufacturer, FallbackValue='SK Hynix'}" />
                                <Run Text=" - " />
                                <Run Text="{Binding SysInfo.RamSticks[0].Speed, FallbackValue='4800'}" />
                                <Run Text=" MHz " />
                                <Run Text="{Binding SysInfo.RamSlotsSummary, FallbackValue='(2/2 slots)'}" />
                            </TextBlock>

                            <Grid Margin="0,40,0,0">
                                <TextBlock Text="Mức sử dụng" Style="{StaticResource MetricLabelStyle}" FontSize="13.5" FontWeight="SemiBold" FontFamily="Rajdhani, Consolas"/>
                                <TextBlock Text="{Binding RamUtilText, FallbackValue='8.4 / 32.0 GB (26%)'}"
                                           Foreground="{StaticResource PurpleAccent}"
                                           HorizontalAlignment="Right" FontSize="14" FontWeight="ExtraBold" FontFamily="Rajdhani, Consolas"/>
                            </Grid>
                            <ProgressBar Margin="0,6,0,0" Height="5" Value="{Binding RamUtil, FallbackValue=26}"
                                         Maximum="100" Foreground="{StaticResource PurpleAccent}" Style="{StaticResource FlatBar}"/>
                        </StackPanel>

                        <!-- RAM Icon with glow -->
                        <Path Data="M2,6H22V10H2V6Z M2,14H22V18H2V14Z M18,7H20V9H18Z M18,15H20V17H18Z"
                              Fill="{StaticResource PurpleAccent}" Width="60" Height="50" Stretch="Fill"
                              HorizontalAlignment="Right" VerticalAlignment="Top" Opacity="0.08">
                            <Path.Effect>
                                <BlurEffect Radius="3"/>
                            </Path.Effect>
                        </Path>
                    </Grid>
                </Border>

               
                <!-- ===== 3. GPU ===== -->
                <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource GlowCardPink}" Margin="0,0,0,20">
                    <Grid Margin="20">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Border Width="3" Height="18" CornerRadius="2" Background="{StaticResource PinkAccent}" Margin="0,0,8,0" VerticalAlignment="Center">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#F052B6" BlurRadius="4" ShadowDepth="0" Opacity="0.3"/>
                                    </Border.Effect>
                                </Border>
                                <TextBlock Text="ĐỒ HỌA (GPU)" FontSize="15" FontWeight="ExtraBold"
                                           Foreground="{StaticResource PinkAccent}" FontFamily="Rajdhani, Consolas">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="#F052B6" BlurRadius="3" ShadowDepth="0" Opacity="0.12"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                            </StackPanel>

                            <ItemsControl ItemsSource="{Binding SysInfo.Gpus}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,0,0,8">
                                            <TextBlock Text="{Binding Name, FallbackValue='NVIDIA RTX 4060'}"
                                                       FontSize="22" Foreground="White" FontWeight="Bold"
                                                       TextWrapping="Wrap" FontFamily="Rajdhani, Consolas"/>
                                            <TextBlock Text="{Binding Vram, StringFormat='{}{0} GDDR6 VRAM', FallbackValue='8 GB GDDR6 VRAM'}"
                                                       FontSize="15" Foreground="{StaticResource MutedText}"
                                                       Margin="0,4,0,0" FontFamily="Rajdhani, Consolas" FontWeight="Bold"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Grid Margin="0,18,0,0">
                                <TextBlock Text="Mức sử dụng" Style="{StaticResource MetricLabelStyle}" FontSize="13.5" FontWeight="SemiBold" FontFamily="Rajdhani, Consolas"/>
                                <TextBlock Text="4%" Foreground="{StaticResource PinkAccent}"
                                           HorizontalAlignment="Right" FontSize="14" FontWeight="ExtraBold" FontFamily="Rajdhani, Consolas"/>
                            </Grid>
                            <ProgressBar Margin="0,6,0,14" Height="5" Value="4"
                                         Maximum="100" Foreground="{StaticResource PinkAccent}" Style="{StaticResource FlatBar}"/>
                        </StackPanel>

                        <!-- GPU Icon with glow -->
                        <Path Data="M11,2 L2,14 H10 L8,22 L18,9 H11 Z"
                              Stroke="{StaticResource PinkAccent}" StrokeThickness="2" Fill="Transparent"
                              Width="38" Height="60" Stretch="Fill"
                              HorizontalAlignment="Right" VerticalAlignment="Top" Opacity="0.08" Margin="0,8,8,0">
                            <Path.Effect>
                                <BlurEffect Radius="3"/>
                            </Path.Effect>
                        </Path>
                    </Grid>
                </Border>

              
                <!-- ===== 4. STORAGE ===== -->
                <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource GlowCardGreen}" Margin="0,0,0,20">
                    <StackPanel Margin="20">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Border Width="3" Height="18" CornerRadius="2" Background="{StaticResource GreenAccent}" Margin="0,0,8,0" VerticalAlignment="Center">
                                <Border.Effect>
                                    <DropShadowEffect Color="#1ae65d" BlurRadius="4" ShadowDepth="0" Opacity="0.3"/>
                                </Border.Effect>
                            </Border>
                            <TextBlock Text="Ổ CỨNG LƯU TRỮ" FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource GreenAccent}" FontFamily="Rajdhani, Consolas">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="#1ae65d" BlurRadius="3" ShadowDepth="0" Opacity="0.12"/>
                                </TextBlock.Effect>
                            </TextBlock>
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding SysInfo.Storages}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#331ae65d" BorderThickness="1" CornerRadius="6"
                                            Background="#08101A" Padding="18,14" Margin="0,0,0,12">
                                        <Border.Effect>
                                            <DropShadowEffect Color="#1ae65d" BlurRadius="5" ShadowDepth="0" Opacity="0.1"/>
                                        </Border.Effect>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <!-- Drive name + icon -->
                                                <StackPanel Orientation="Horizontal">
                                                    <Path Data="M6,2H18A2,2 0 0,1 20,4V20A2,2 0 0,1 18,22H6A2,2 0 0,1 4,20V4A2,2 0 0,1 6,2M6,4V20H18V4H6M8,6H16V8H8V6M8,10H16V12H8V10M8,14H12V16H8V14Z"
                                                          Fill="{StaticResource GreenAccent}" Width="20" Height="20"
                                                          Margin="0,0,12,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Model, FallbackValue='Samsung PM9A1 1TB'}"
                                                               FontSize="19" Foreground="White" FontWeight="Bold"
                                                               VerticalAlignment="Center" FontFamily="Rajdhani, Consolas"/>
                                                </StackPanel>

                                                <!-- Type + Capacity -->
                                                <StackPanel Orientation="Horizontal" Margin="32,4,0,0">
                                                    <TextBlock Text="{Binding Type, FallbackValue='NVMe (PCIe M.2) [SSD]'}"
                                                               FontSize="12.5" Style="{StaticResource MutedLabelStyle}"
                                                               FontFamily="Rajdhani, Consolas" FontWeight="SemiBold"/>
                                                    <TextBlock Text=" · " Style="{StaticResource MutedLabelStyle}" FontSize="11"/>
                                                    <TextBlock Text="{Binding Capacity, FallbackValue='512 GB'}"
                                                               FontSize="12.5" Style="{StaticResource MutedLabelStyle}"
                                                               FontFamily="Rajdhani, Consolas" FontWeight="SemiBold"/>
                                                </StackPanel>

                                                <!-- Metrics row -->
                                                <StackPanel Orientation="Horizontal" Margin="32,16,0,0">
                                                    <Border BorderBrush="#221ae65d" BorderThickness="1" CornerRadius="4"
                                                            Padding="12,7" Margin="0,0,8,0" Background="Transparent" MinWidth="100">
                                                        <StackPanel>
                                                            <TextBlock Text="NHIỆT ĐỘ" Style="{StaticResource MetricLabelStyle}"
                                                                       FontSize="11" FontWeight="ExtraBold" FontFamily="Consolas"/>
                                                            <TextBlock Text="{Binding Temperature, StringFormat='{}{0}°C', FallbackValue='--'}"
                                                                       FontSize="20" Foreground="{StaticResource OrangeAccent}" FontWeight="Bold"
                                                                       Margin="0,3,0,0" FontFamily="Rajdhani, Consolas"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <Border BorderBrush="#221ae65d" BorderThickness="1" CornerRadius="4"
                                                            Padding="12,7" Margin="0,0,8,0" Background="Transparent" MinWidth="100">
                                                        <StackPanel>
                                                            <TextBlock Text="ĐÃ GHI" Style="{StaticResource MetricLabelStyle}"
                                                                       FontSize="11" FontWeight="ExtraBold" FontFamily="Consolas"/>
                                                            <TextBlock Text="{Binding TotalHostWrites, FallbackValue='N/A'}"
                                                                       FontSize="19" Foreground="White" FontWeight="Bold"
                                                                       Margin="0,3,0,0" FontFamily="Rajdhani, Consolas"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <Border BorderBrush="#221ae65d" BorderThickness="1" CornerRadius="4"
                                                            Padding="12,7" Margin="0,0,8,0" Background="Transparent" MinWidth="100">
                                                        <StackPanel>
                                                            <TextBlock Text="DỰ PHÒNG" Style="{StaticResource MetricLabelStyle}"
                                                                       FontSize="11" FontWeight="ExtraBold" FontFamily="Consolas"/>
                                                            <TextBlock Text="{Binding AvailableSpare, StringFormat='{}{0}%', FallbackValue='--'}"
                                                                       FontSize="20" Foreground="{StaticResource CyanAccent}" FontWeight="Bold"
                                                                       Margin="0,3,0,0" FontFamily="Rajdhani, Consolas"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <Border BorderBrush="#221ae65d" BorderThickness="1" CornerRadius="4"
                                                            Padding="12,7" Background="Transparent" MinWidth="100">
                                                        <StackPanel>
                                                            <TextBlock Text="GIỜ CHẠY" Style="{StaticResource MetricLabelStyle}"
                                                                       FontSize="11" FontWeight="ExtraBold" FontFamily="Consolas"/>
                                                            <TextBlock Text="{Binding PowerOnDays, StringFormat='{}{0} days', FallbackValue='--'}"
                                                                       FontSize="20" Style="{StaticResource MutedLabelStyle}" FontWeight="Bold"
                                                                       Margin="0,3,0,0" FontFamily="Rajdhani, Consolas"/>
                                                        </StackPanel>
                                                    </Border>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Health Box (right) with green glow -->
                                            <Border Grid.Column="1" VerticalAlignment="Center" Margin="20,0,0,0"
                                                    Background="#06120A" BorderBrush="#331ae65d" BorderThickness="1"
                                                    CornerRadius="6" Padding="20,15" MinWidth="140">
                                                <Border.Effect>
                                                    <DropShadowEffect Color="#1ae65d" BlurRadius="6" ShadowDepth="0" Opacity="0.15"/>
                                                </Border.Effect>
                                                <StackPanel HorizontalAlignment="Center">
                                                    <TextBlock Text="SỨC KHỎE" Style="{StaticResource MetricLabelStyle}"
                                                               FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"
                                                               FontFamily="Consolas" Margin="0,0,0,6"/>
                                                    <TextBlock Text="{Binding HealthRemaining, StringFormat='{}{0}%', FallbackValue='--'}"
                                                               FontSize="38" Foreground="{StaticResource GreenAccent}"
                                                               FontWeight="Bold" HorizontalAlignment="Center"
                                                               FontFamily="Rajdhani, Consolas">
                                                        <TextBlock.Effect>
                                                            <DropShadowEffect Color="#1ae65d" BlurRadius="4" ShadowDepth="0" Opacity="0.2"/>
                                                        </TextBlock.Effect>
                                                    </TextBlock>
                                                    <ProgressBar Margin="0,8,0,8" Height="5" Width="100"
                                                                 Value="{Binding HealthRemaining, FallbackValue=0}"
                                                                 Maximum="100" Foreground="{StaticResource GreenAccent}"
                                                                 Style="{StaticResource FlatBar}"/>
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                        <TextBlock Text="&#x2713;" FontSize="10" Foreground="{StaticResource GreenAccent}"
                                                                   Margin="0,0,4,0" FontWeight="Black" FontFamily="Consolas"/>
                                                        <TextBlock Text="SMART OK" FontSize="10"
                                                                   Foreground="{StaticResource GreenAccent}"
                                                                   FontWeight="Bold" FontFamily="Consolas"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

               
                <!-- ===== 5. BATTERY ===== -->
                <Border Grid.Row="1" Grid.Column="4" Style="{StaticResource GlowCardOrange}" Margin="0,0,0,20">
                    <Grid Margin="20">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Border Width="3" Height="18" CornerRadius="2" Background="{StaticResource OrangeAccent}" Margin="0,0,8,0" VerticalAlignment="Center">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#FFB800" BlurRadius="4" ShadowDepth="0" Opacity="0.3"/>
                                    </Border.Effect>
                                </Border>
                                <TextBlock Text="NGUỒN (PIN)" FontSize="15" FontWeight="ExtraBold"
                                           Foreground="{StaticResource OrangeAccent}" FontFamily="Rajdhani, Consolas">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="#FFB800" BlurRadius="3" ShadowDepth="0" Opacity="0.12"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                            </StackPanel>

                            <TextBlock Text="{Binding SysInfo.BatteryHealth, FallbackValue='85%'}"
                                       FontSize="36" Foreground="White" FontWeight="SemiBold" FontFamily="Rajdhani, Consolas"/>

                            <StackPanel Orientation="Horizontal" Margin="0,6,0,10">
                                <Path Data="M11,2 L2,14 H10 L8,22 L18,9 H11 Z" Fill="{StaticResource OrangeAccent}"
                                      Width="8" Height="12" Stretch="Fill" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding BatteryStatus, FallbackValue='ĐANG SẠC'}" FontSize="12.5"
                                           Foreground="{StaticResource OrangeAccent}" FontWeight="Bold"
                                           FontFamily="Rajdhani, Consolas"/>
                            </StackPanel>

                            <Grid Margin="0,0,0,22">
                                <TextBlock Text="Dòng điện:" Style="{StaticResource MetricLabelStyle}" FontSize="13.5" FontWeight="SemiBold" FontFamily="Rajdhani, Consolas"/>
                                <TextBlock Text="{Binding BatteryRate, FallbackValue='0 W'}" Foreground="White"
                                           HorizontalAlignment="Right" FontSize="14" FontWeight="Bold" FontFamily="Rajdhani, Consolas"/>
                            </Grid>

                            <Grid Margin="0,10,0,8">
                                <TextBlock Text="Dung lượng thiết kế" Style="{StaticResource MetricLabelStyle}" FontSize="13.5" FontWeight="SemiBold" FontFamily="Rajdhani, Consolas"/>
                                <TextBlock Text="{Binding SysInfo.BatteryDesignCapacity, FallbackValue='76,000 mWh'}"
                                           Foreground="White" HorizontalAlignment="Right" FontSize="12"
                                           FontWeight="SemiBold" FontFamily="Rajdhani, Consolas"/>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="Sạc đầy hiện tại" Style="{StaticResource MetricLabelStyle}" FontSize="13.5" FontWeight="SemiBold" FontFamily="Rajdhani, Consolas"/>
                                <TextBlock Text="{Binding SysInfo.BatteryFullChargeCapacity, FallbackValue='72,450 mWh'}"
                                           Foreground="White" HorizontalAlignment="Right" FontSize="12"
                                           FontWeight="SemiBold" FontFamily="Rajdhani, Consolas"/>
                            </Grid>
                            <Grid>
                                <TextBlock Text="Độ chai pin:" Style="{StaticResource MetricLabelStyle}" FontSize="13.5" FontWeight="SemiBold" FontFamily="Rajdhani, Consolas"/>
                                <TextBlock Text="{Binding SysInfo.BatteryWearPercent, FallbackValue='4.6%'}"
                                           Foreground="{StaticResource DangerAccent}" HorizontalAlignment="Right"
                                           FontSize="14" FontWeight="ExtraBold" FontFamily="Rajdhani, Consolas"/>
                            </Grid>
                        </StackPanel>

                        <!-- Battery Icon with glow -->
                        <Path Data="M4,6 H20 V10 H22 V14 H20 V18 H4 V6 Z"
                              Stroke="{StaticResource OrangeAccent}" StrokeThickness="1.5" Fill="Transparent"
                              Width="44" Height="28" Stretch="Fill"
                              HorizontalAlignment="Right" VerticalAlignment="Top" Opacity="0.08">
                            <Path.Effect>
                                <BlurEffect Radius="3"/>
                            </Path.Effect>
                        </Path>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>

        <!-- Loading overlay with pulsing glow -->
        <Grid Grid.RowSpan="2" Background="#DD070A10"
              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="5"
                             Foreground="{StaticResource CyanAccent}" Style="{StaticResource FlatBar}"/>
                <TextBlock Text="ĐANG CHẠY QUÉT PHẦN CỨNG..." Foreground="{StaticResource CyanAccent}"
                           Margin="0,15,0,0" HorizontalAlignment="Center" FontSize="12"
                           FontFamily="Rajdhani, Consolas" FontWeight="Bold">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#00D2FF" BlurRadius="8" ShadowDepth="0" Opacity="0.3"/>
                    </TextBlock.Effect>
                </TextBlock>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
