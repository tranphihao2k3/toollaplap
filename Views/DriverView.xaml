<UserControl x:Class="LapLapAutoTool.Views.DriverView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="900">

    <UserControl.Resources>
        <SolidColorBrush x:Key="GreenAccent" Color="#1ae65d"/>
        <SolidColorBrush x:Key="GreenDim" Color="#151ae65d"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                  Background="Transparent" Padding="32,24">
        <StackPanel>

            <!-- ===== HEADER: Model Detection ===== -->
            <Border Background="#0A1E293B" BorderBrush="{StaticResource GreenAccent}" BorderThickness="1"
                    CornerRadius="8" Padding="20,16" Margin="0,0,0,20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Section Title -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Background="{StaticResource GreenAccent}" CornerRadius="3" Padding="8,3" Margin="0,0,10,0">
                            <TextBlock Text="DRIVER INSTALLER" FontFamily="Consolas" FontSize="11" FontWeight="Bold" Foreground="#08080D"/>
                        </Border>
                        <TextBlock Text="Cai Driver Theo Model" FontFamily="Consolas" FontSize="14" FontWeight="Bold"
                                   Foreground="{StaticResource GreenAccent}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Detected Model -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="Model phat hien: " FontFamily="Consolas" FontSize="13" Foreground="{StaticResource MutedTextBrush}"/>
                        <TextBlock Text="{Binding DetectedModel}" FontFamily="Consolas" FontSize="13" FontWeight="Bold" Foreground="White"/>
                    </StackPanel>

                    <!-- Match Status -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{StaticResource GreenAccent}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding MatchedConfigModel}" Value="">
                                            <Setter Property="Fill" Value="{StaticResource DangerBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding MatchStatus}" FontFamily="Consolas" FontSize="12" Foreground="{StaticResource MutedTextBrush}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ===== DRIVER LIST ===== -->
            <Border Background="#0A1E293B" BorderBrush="#1500F2FF" BorderThickness="1"
                    CornerRadius="8" Padding="0" Margin="0,0,0,20">

                <StackPanel>
                    <!-- List Header -->
                    <Grid Margin="16,12,16,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <CheckBox IsChecked="{Binding IsAllSelected}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="DANH SACH DRIVER" FontFamily="Consolas" FontSize="12" FontWeight="Bold"
                                       Foreground="{StaticResource GreenAccent}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <Button Command="{Binding RefreshCommand}" Background="Transparent" BorderThickness="0" Cursor="Hand"
                                    Padding="8,4" ToolTip="Lam moi danh sach">
                                <TextBlock Text="Lam moi" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource PrimaryBrush}"/>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- Column Headers -->
                    <Grid Margin="16,0,16,0" Height="32">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="200"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.ColumnSpan="4" BorderBrush="#10FFFFFF" BorderThickness="0,0,0,1" VerticalAlignment="Bottom"/>
                        <TextBlock Grid.Column="1" Text="Driver" FontFamily="Consolas" FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="Loai" FontFamily="Consolas" FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="Trang thai" FontFamily="Consolas" FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Driver Items -->
                    <ItemsControl ItemsSource="{Binding DriverList}" Margin="16,0,16,12">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid MinHeight="48" Cursor="Hand"
                                      MouseLeftButtonDown="DriverRow_Click">
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#08FFFFFF"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="36"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="200"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.ColumnSpan="4" BorderBrush="#08FFFFFF" BorderThickness="0,0,0,1" VerticalAlignment="Bottom"/>

                                    <!-- Checkbox -->
                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" IsHitTestVisible="False"
                                              VerticalAlignment="Center" HorizontalAlignment="Center"/>

                                    <!-- Name + Description -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="4,4,8,4">
                                        <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="Bold" FontFamily="Consolas" Foreground="White"/>
                                        <TextBlock Text="{Binding Description}" FontSize="11" FontFamily="Consolas" Foreground="{StaticResource MutedTextBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>

                                    <!-- Category Badge -->
                                    <Border Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center"
                                            Background="{StaticResource GreenDim}" CornerRadius="3" Padding="8,2">
                                        <TextBlock Text="{Binding Category}" FontFamily="Consolas" FontSize="10" FontWeight="Bold"
                                                   Foreground="{StaticResource GreenAccent}"/>
                                    </Border>

                                    <!-- Status -->
                                    <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="8,0,0,0">
                                        <TextBlock FontFamily="Consolas" FontSize="11">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
                                                    <Setter Property="Text" Value="{Binding StatusText}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                            <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                            <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Installing">
                                                            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Downloading">
                                                            <Setter Property="Foreground" Value="#A855F7"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <!-- Mini progress bar for downloading -->
                                        <ProgressBar Height="3" Value="{Binding Progress}" Maximum="100" Margin="0,3,0,0"
                                                     Background="#15FFFFFF" Foreground="{StaticResource GreenAccent}">
                                            <ProgressBar.Style>
                                                <Style TargetType="ProgressBar">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Downloading">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ProgressBar.Style>
                                        </ProgressBar>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- ===== BOTTOM: Progress + Install Button ===== -->
            <Border Background="#0A1E293B" BorderBrush="#1500F2FF" BorderThickness="1"
                    CornerRadius="8" Padding="20,16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Progress Bar -->
                    <ProgressBar Grid.Row="0" Height="6" Value="{Binding Progress}" Maximum="100"
                                 Background="#15FFFFFF" Foreground="{StaticResource GreenAccent}" Margin="0,0,0,12">
                        <ProgressBar.Style>
                            <Style TargetType="ProgressBar">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ProgressBar.Style>
                    </ProgressBar>

                    <!-- Status Text -->
                    <TextBlock Grid.Row="1" Text="{Binding StatusText}" FontFamily="Consolas" FontSize="12"
                               Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,12"/>

                    <!-- Action Buttons -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <!-- Cancel Button -->
                        <Button Command="{Binding CancelCommand}" Cursor="Hand"
                                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                                Margin="0,0,12,0" Padding="20,10"
                                Background="Transparent" BorderBrush="{StaticResource DangerBrush}" BorderThickness="1.5">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <TextBlock Text="HUY" FontFamily="Consolas" FontSize="13" FontWeight="Bold" Foreground="{StaticResource DangerBrush}"/>
                        </Button>

                        <!-- Install Button -->
                        <Button Command="{Binding InstallSelectedCommand}" Cursor="Hand"
                                Padding="28,10">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{StaticResource GreenAccent}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                                        <Setter Property="Background" Value="#555"/>
                                                    </DataTrigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#20E860"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <TextBlock Text="CAI DRIVER" FontFamily="Consolas" FontSize="14" FontWeight="Black" Foreground="#08080D"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ===== BACKUP & UPLOAD GOOGLE DRIVE ===== -->
            <Border Background="#0A1E293B" BorderBrush="{StaticResource GreenAccent}" BorderThickness="1"
                    CornerRadius="8" Padding="20,16" Margin="0,20,0,0">
                <StackPanel>

                    <!-- Section Title -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Border Background="#A855F7" CornerRadius="3" Padding="8,3" Margin="0,0,10,0">
                            <TextBlock Text="BACKUP" FontFamily="Consolas" FontSize="11" FontWeight="Bold" Foreground="White"/>
                        </Border>
                        <TextBlock Text="Backup Driver &amp; Upload Google Drive" FontFamily="Consolas" FontSize="14" FontWeight="Bold"
                                   Foreground="#A855F7" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Google Drive Config -->
                    <Border Background="#08FFFFFF" CornerRadius="6" Padding="16,12" Margin="0,0,0,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Auth Status -->
                            <TextBlock Grid.Row="0" Grid.ColumnSpan="2" FontFamily="Consolas" FontSize="12"
                                       Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,10">
                                <Run Text="Trang thai: "/>
                                <Run Text="{Binding DriveAuthStatus}" FontWeight="Bold" Foreground="White"/>
                            </TextBlock>

                            <!-- Client ID -->
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Client ID:" FontFamily="Consolas" FontSize="12"
                                       Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding ClientId, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="Consolas" FontSize="12" Background="#15FFFFFF" Foreground="White"
                                     BorderBrush="#30FFFFFF" BorderThickness="1" Padding="8,6" Margin="0,0,0,8"/>

                            <!-- Client Secret -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Client Secret:" FontFamily="Consolas" FontSize="12"
                                       Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" Margin="0,0,0,8"/>
                            <PasswordBox Grid.Row="2" Grid.Column="1" x:Name="ClientSecretBox"
                                         FontFamily="Consolas" FontSize="12" Background="#15FFFFFF" Foreground="White"
                                         BorderBrush="#30FFFFFF" BorderThickness="1" Padding="8,6" Margin="0,0,0,8"
                                         PasswordChanged="ClientSecretBox_PasswordChanged"/>

                            <!-- Config Buttons -->
                            <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="0,4,0,0">
                                <!-- Save Config -->
                                <Button Command="{Binding SaveDriveConfigCommand}" Cursor="Hand" Margin="0,0,8,0" Padding="14,6">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="#30FFFFFF" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <TextBlock Text="Luu" FontFamily="Consolas" FontSize="11" Foreground="White"/>
                                </Button>

                                <!-- Connect -->
                                <Button Command="{Binding ConnectDriveCommand}" Cursor="Hand" Margin="0,0,8,0" Padding="14,6">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="#A855F7" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <TextBlock Text="Ket noi Drive" FontFamily="Consolas" FontSize="11" FontWeight="Bold" Foreground="White"/>
                                </Button>

                                <!-- Disconnect -->
                                <Button Command="{Binding DisconnectDriveCommand}" Cursor="Hand" Padding="14,6">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="Transparent" BorderBrush="#60FFFFFF" BorderThickness="1"
                                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <TextBlock Text="Ngat ket noi" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource MutedTextBrush}"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Backup Progress Bar -->
                    <ProgressBar Height="6" Value="{Binding BackupProgress}" Maximum="100"
                                 Background="#15FFFFFF" Foreground="#A855F7" Margin="0,0,0,8">
                        <ProgressBar.Style>
                            <Style TargetType="ProgressBar">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBackupBusy}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ProgressBar.Style>
                    </ProgressBar>

                    <!-- Backup Status Text -->
                    <TextBlock Text="{Binding BackupStatusText}" FontFamily="Consolas" FontSize="12"
                               Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,12"
                               TextWrapping="Wrap"/>

                    <!-- Backup Action Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <!-- Cancel Backup -->
                        <Button Command="{Binding CancelBackupCommand}" Cursor="Hand"
                                Visibility="{Binding IsBackupBusy, Converter={StaticResource BoolToVis}}"
                                Margin="0,0,12,0" Padding="20,10"
                                Background="Transparent" BorderBrush="{StaticResource DangerBrush}" BorderThickness="1.5">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <TextBlock Text="HUY" FontFamily="Consolas" FontSize="13" FontWeight="Bold" Foreground="{StaticResource DangerBrush}"/>
                        </Button>

                        <!-- Backup & Upload Button -->
                        <Button Command="{Binding BackupAndUploadCommand}" Cursor="Hand" Padding="28,10">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#A855F7"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsBackupBusy}" Value="True">
                                                        <Setter Property="Background" Value="#555"/>
                                                    </DataTrigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#B96CF9"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <TextBlock Text="BACKUP &amp; UPLOAD" FontFamily="Consolas" FontSize="14" FontWeight="Black" Foreground="White"/>
                        </Button>
                    </StackPanel>

                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
