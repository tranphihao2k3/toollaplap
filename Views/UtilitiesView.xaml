<UserControl x:Class="LapLapAutoTool.Views.UtilitiesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Công cụ hệ thống" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
            <TextBlock Text="Tối ưu và bảo trì hệ thống với công cụ 1-click" Foreground="{StaticResource MutedTextBrush}" FontSize="14"/>
        </StackPanel>

        <!-- Content Area -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <UniformGrid Columns="2">
                <!-- Optimization Card -->
                <Border Style="{StaticResource ModernCard}" Margin="10">
                    <StackPanel>
                        <TextBlock Text="TỐI ƯU 1-CLICK" FontSize="11" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,15"/>
                        
                        <Button Content="Tắt Windows Update" 
                                Command="{Binding DisableUpdateCommand}" 
                                Style="{StaticResource SecondaryButton}" 
                                Margin="0,0,0,10" HorizontalAlignment="Stretch"/>
                                
                        <Button Content="Tắt Windows Defender" 
                                Command="{Binding DisableDefenderCommand}" 
                                Style="{StaticResource SecondaryButton}" 
                                Margin="0,0,0,10" HorizontalAlignment="Stretch"/>
                                
                        <Button Content="Tắt Fast Boot" 
                                Command="{Binding DisableFastBootCommand}" 
                                Style="{StaticResource SecondaryButton}" 
                                Margin="0,0,0,10" HorizontalAlignment="Stretch"/>
                                
                        <Button Content="Dọn dẹp file rác/tạm" 
                                Command="{Binding CleanTempCommand}" 
                                Style="{StaticResource ModernButton}" 
                                HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </Border>

                <!-- More utilities can be added here -->
                <Border Style="{StaticResource ModernCard}" Margin="10" Opacity="0.6">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Đồng bộ &amp; Sao lưu đám mây" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                        <TextBlock Text="Sắp có trên bản Pro" FontSize="12" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </UniformGrid>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Grid Grid.RowSpan="2" Background="#88000000" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4"/>
                <TextBlock Text="Đang áp dụng cài đặt..." Foreground="White" Margin="0,10,0,0" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
