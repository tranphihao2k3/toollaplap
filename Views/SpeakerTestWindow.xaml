<Window x:Class="LapLapAutoTool.Views.SpeakerTestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Test Loa &amp; Âm Thanh" Width="560" Height="540"
        WindowStartupLocation="CenterScreen"
        Background="#0F172A"
        ResizeMode="NoResize"
        Closed="Window_Closed">
    <Grid Margin="24,20,24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="🔊 Test Loa &amp; Âm Thanh"
                   FontSize="22" FontWeight="Black" Foreground="White" Margin="0,0,0,4"/>
        <TextBlock Grid.Row="1" Text="Phát tone thuần, kiểm tra stereo, hoặc tải nhạc về để test"
                   FontSize="12" Foreground="#94A3B8" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="2">

            <!-- SECTION: Tone thuần -->
            <TextBlock Text="TONE THUẦN" Foreground="#475569" FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
            <Grid Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Bass 220Hz"  Tag="220" Click="PlayToneClick"
                        Margin="0,0,4,0" Padding="8,11" Style="{StaticResource ModernButton}" FontSize="12"/>
                <Button Grid.Column="1" Content="Mid 440Hz"   Tag="440" Click="PlayToneClick"
                        Margin="4,0" Padding="8,11" Style="{StaticResource ModernButton}" FontSize="12"/>
                <Button Grid.Column="2" Content="High 1000Hz" Tag="1000" Click="PlayToneClick"
                        Margin="4,0,0,0" Padding="8,11" Style="{StaticResource ModernButton}" FontSize="12"/>
            </Grid>

            <!-- SECTION: Stereo -->
            <TextBlock Text="STEREO CHECK" Foreground="#475569" FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
            <Grid Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="◄ Loa Trái" Click="PlayLeft"
                        Margin="0,0,4,0" Padding="8,11" Style="{StaticResource ModernButton}" FontSize="12"/>
                <Button Grid.Column="1" Content="● Cả Hai"   Click="PlayBoth"
                        Margin="4,0" Padding="8,11" Style="{StaticResource ModernButton}" FontSize="12"/>
                <Button Grid.Column="2" Content="Loa Phải ►" Click="PlayRight"
                        Margin="4,0,0,0" Padding="8,11" Style="{StaticResource ModernButton}" FontSize="12"/>
            </Grid>

            <!-- SECTION: Download + Play music -->
            <TextBlock Text="PHÁT NHẠC TỪ LINK" Foreground="#475569" FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="#1E293B" CornerRadius="6" BorderBrush="#334155" BorderThickness="1"
                        Margin="0,0,6,0">
                    <TextBox x:Name="UrlBox"
                             Background="Transparent" BorderThickness="0"
                             Foreground="White" CaretBrush="White"
                             FontSize="12" Padding="10,9"
                             VerticalContentAlignment="Center"
                             Text="https://..."
                             GotFocus="UrlBox_GotFocus"/>
                </Border>
                <Button Grid.Column="1" x:Name="BtnDownload"
                        Content="⬇ Tải &amp; Phát" Click="DownloadAndPlay"
                        Padding="14,10" Style="{StaticResource AccentButton}" FontSize="12"/>
            </Grid>
            <Button Content="📂 Chọn file nhạc từ máy..." Click="OpenLocalFile"
                    HorizontalAlignment="Left" Padding="12,7" Margin="0,0,0,14"
                    Style="{StaticResource GhostButton}" FontSize="12"/>

            <!-- Volume -->
            <TextBlock Text="ÂM LƯỢNG" Foreground="#475569" FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
            <Grid Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="40"/>
                </Grid.ColumnDefinitions>
                <Slider Grid.Column="0" x:Name="VolumeSlider" Minimum="0" Maximum="100" Value="70"
                        VerticalAlignment="Center" Foreground="#2563EB"
                        ValueChanged="VolumeChanged"/>
                <TextBlock Grid.Column="1" x:Name="VolLabel" Text="70%"
                           Foreground="White" FontSize="12" FontWeight="Bold"
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Grid>

            <!-- Status + Controls -->
            <Border Background="#1E293B" CornerRadius="8" Padding="14,10" Margin="0,0,0,14">
                <StackPanel Orientation="Horizontal">
                    <Ellipse x:Name="PlayDot" Width="8" Height="8" Fill="#334155"
                             VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock x:Name="StatusText"
                               Text="Sẵn sàng — chọn tone hoặc tải nhạc để bắt đầu"
                               Foreground="#94A3B8" FontSize="12" VerticalAlignment="Center"
                               TextWrapping="Wrap" MaxWidth="380"/>
                </StackPanel>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="ProgressText" Text="" Foreground="#475569"
                           FontSize="11" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="⏹ Dừng" Click="Stop_Click"
                        Padding="16,9" Style="{StaticResource SecondaryButton}" FontSize="12" Margin="0,0,6,0"/>
                <Button Grid.Column="2" Content="Đóng" Click="Stop_Click"
                        Padding="16,9" Style="{StaticResource ModernButton}" FontSize="12"/>
            </Grid>
        </StackPanel>
    </Grid>
</Window>
