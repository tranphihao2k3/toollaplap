<UserControl x:Class="LapLapAutoTool.Views.KeyboardTestControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Background="#070A10"
             Focusable="True"
             PreviewKeyDown="Control_PreviewKeyDown"
             KeyDown="Control_KeyDown"
             KeyUp="Control_KeyUp"
             Loaded="Control_Loaded">
    <Grid Margin="16,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Keyboard Canvas -->
        <Viewbox Grid.Row="0" Stretch="Uniform" Margin="0,0,0,10"
                 MaxWidth="950" MaxHeight="280"
                 HorizontalAlignment="Center" VerticalAlignment="Center">
            <Canvas x:Name="KeyboardCanvas"
                    Width="690" Height="178"/>
        </Viewbox>

        <!-- Status Bar -->
        <Border Grid.Row="1" Background="#0B101A" CornerRadius="6" Padding="12,6"
                BorderBrush="#1A6366F1" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Phím: " Foreground="#4A7A8A" FontSize="12" VerticalAlignment="Center"
                               FontFamily="Rajdhani, Consolas"/>
                    <TextBlock x:Name="PressedKeyText" Text="-"
                               Foreground="#00D2FF" FontSize="13" FontWeight="ExtraBold" VerticalAlignment="Center"
                               FontFamily="Rajdhani, Consolas"/>
                    <TextBlock Text="   |   " Foreground="#1E293B" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock x:Name="StatusText" Text="Đã test: 0 / 0"
                               Foreground="#1ae65d" FontSize="13" FontWeight="ExtraBold" VerticalAlignment="Center"
                               FontFamily="Rajdhani, Consolas"/>
                </StackPanel>
                <Button Grid.Column="1" Content="Reset" Click="Reset_Click"
                        Padding="14,4" Style="{StaticResource ModernButton}" FontSize="11"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
