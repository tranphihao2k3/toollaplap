<Window x:Class="LapLapAutoTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="clr-namespace:LapLapAutoTool.ViewModels"
        xmlns:views="clr-namespace:LapLapAutoTool.Views"
        xmlns:converters="clr-namespace:LapLapAutoTool.Converters"
        mc:Ignorable="d"
        Title="LapLap Auto Setup" 
        Height="780" Width="1100"
        MinHeight="700" MinWidth="900"
        Icon="/Resources/app_icon.png"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        TextOptions.TextFormattingMode="Display"
        RenderOptions.ClearTypeHint="Enabled">

    <Window.DataContext>
        <viewmodels:MainWindowViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        
        <!-- DataTemplates to link ViewModels to Views -->
        <DataTemplate DataType="{x:Type viewmodels:HardwareViewModel}">
            <views:HardwareView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:QuickSetupViewModel}">
            <views:QuickSetupView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:StudentAppsViewModel}">
            <views:StudentAppsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:UtilitiesViewModel}">
            <views:UtilitiesView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:BackupViewModel}">
            <views:BackupView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:SettingsViewModel}">
            <views:SettingsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:LaptopTestViewModel}">
            <views:LaptopTestView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:UninstallViewModel}">
            <views:UninstallView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:AssessmentViewModel}">
            <views:AssessmentView/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Top bar -->
            <RowDefinition Height="*"/>     <!-- Main -->
            <RowDefinition Height="Auto"/> <!-- Bottom bar -->
        </Grid.RowDefinitions>

        <!-- ===== TOP STATUS BAR (Cyberpunk style) ===== -->
        <Border Grid.Row="0" Background="#08080D" BorderBrush="#1500F2FF" BorderThickness="0,0,0,1" Padding="20,8">
            <Grid>
                <!-- Left: SYS_NODE -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Path Data="M17,8C8,10 5.9,16.17 3.82,19.34C2.63,21.07 1,22 1,22H23C23,22 7.9,15.1 17,8Z"
                          Fill="{StaticResource PrimaryBrush}" Width="14" Height="14" Stretch="Uniform" Margin="0,0,8,0"/>
                    <TextBlock FontFamily="Consolas" FontSize="11" Foreground="{StaticResource MutedTextBrush}">
                        <Run Text="SYS_NODE:"/>
                        <Run Text=" LOCAL_HOST_002" Foreground="White" FontWeight="Bold"/>
                    </TextBlock>
                </StackPanel>
                <!-- Right: SECURE CONNECTION -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Ellipse Width="6" Height="6" Fill="{StaticResource PrimaryBrush}" Margin="0,0,6,0"/>
                    <TextBlock Text="SECURE CONNECTION" FontFamily="Consolas" FontSize="11" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== MAIN LAYOUT ===== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="#09090F" BorderBrush="#1500F2FF" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Logo -->
                    <StackPanel Grid.Row="0" Margin="18,22,18,22">
                        <StackPanel Orientation="Horizontal">
                            <Border Background="{StaticResource PrimaryBrush}" CornerRadius="4" Width="28" Height="28" Margin="0,0,10,0">
                                <TextBlock Text="L" FontSize="16" FontWeight="Black" Foreground="#08080D" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="LAPLAP" FontSize="14" FontWeight="Black" Foreground="White" FontFamily="Consolas"/>
                                <TextBlock Text="AUTO SETUP" FontSize="8" FontFamily="Consolas" Foreground="{StaticResource PrimaryBrush}" Margin="0,-1,0,0"/>
                            </StackPanel>
                        </StackPanel>
                        <!-- Customer Greeting -->
                        <Border Background="#1500F2FF" BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="1"
                                CornerRadius="4" Padding="8,4" Margin="0,12,0,0" HorizontalAlignment="Left"
                                Visibility="{Binding GreetingVisibility}">
                            <TextBlock Text="{Binding CustomerGreeting}" FontWeight="Bold" FontFamily="Consolas"
                                       Foreground="{StaticResource PrimaryBrush}" FontSize="10" TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>

                    <!-- Section label -->
                    <TextBlock Grid.Row="1" Text="SYSTEM MODULES" FontSize="9" FontFamily="Consolas" FontWeight="Bold"
                               Foreground="{StaticResource MutedTextBrush}" Margin="18,0,0,10"/>

                    <!-- Nav Items -->
                    <StackPanel Grid.Row="2">
                        <RadioButton Style="{StaticResource SidebarButton}" Content="Hardware Scan" Command="{Binding ShowHardwareCommand}" IsChecked="True"/>
                        <RadioButton Style="{StaticResource SidebarButton}" Content="Auto Install" Command="{Binding ShowQuickSetupCommand}"/>
                        <RadioButton Style="{StaticResource SidebarButton}" Content="Student Apps" Command="{Binding ShowStudentAppsCommand}"/>
                        <RadioButton Style="{StaticResource SidebarButton}" Content="System Tools" Command="{Binding ShowUtilitiesCommand}"/>
                        <RadioButton Style="{StaticResource SidebarButton}" Content="Backup Data" Command="{Binding ShowBackupCommand}"/>
                        <RadioButton Style="{StaticResource SidebarButton}" Content="Test Functions" Command="{Binding ShowLaptopTestCommand}"/>
                        <RadioButton Style="{StaticResource SidebarButton}" Content="Remove Apps" Command="{Binding ShowUninstallCommand}"/>
                        <RadioButton Style="{StaticResource SidebarButton}" Content="Assessment" Command="{Binding ShowAssessmentCommand}"/>
                    </StackPanel>

                    <!-- Bottom nav -->
                    <StackPanel Grid.Row="3" Margin="0,0,0,12">
                        <Separator Background="#1500F2FF" Margin="18,8"/>
                        <RadioButton Style="{StaticResource SidebarButton}" Content="Settings &amp; License" Command="{Binding ShowSettingsCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main Content Area -->
            <ContentControl Grid.Column="1" Content="{Binding CurrentView}"/>
        </Grid>

        <!-- Unified Bottom Status Bar -->
        <Border Grid.Row="2" Background="#08080D" BorderBrush="#1500F2FF" BorderThickness="0,1,0,0" Padding="15,8">
            <Grid>
                <!-- Left Details (Admin, HWID, System Status) -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <TextBlock Text="Chế độ Quản trị viên" Foreground="#10B981" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,15,0"/>
                    
                    <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="0,0,15,0" Background="#334155"/>
                    <TextBlock Text="HWID:" Foreground="{StaticResource MutedTextBrush}" FontSize="11" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <Button Content="{Binding MachineCode}" 
                            Command="{Binding CopyHWIDCommand}" 
                            Style="{StaticResource SidebarHWIDButton}" 
                            ToolTip="Mã máy HWID - Click để Copy"
                            FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}"
                            VerticalAlignment="Center" Padding="0"/>

                    <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="15,0" Background="#334155"/>
                    <TextBlock Text="Trạng thái hệ thống: " Foreground="{StaticResource MutedTextBrush}" FontSize="11" VerticalAlignment="Center"/>
                    <TextBlock Text="Sẵn sàng" Foreground="White" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="10,0" Background="#334155"/>
                    <TextBlock Text="Bảo vệ: Bình thường" Foreground="{StaticResource MutedTextBrush}" FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>
                
                <!-- Right Details (Log, License, Version) -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="Truy cập log lỗi" 
                            Command="{Binding OpenLogCommand}"
                            Foreground="{StaticResource MutedTextBrush}" 
                            FontSize="11" Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="0,0,15,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <TextBlock Text="{TemplateBinding Content}" TextDecorations="Underline"/>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,15,0">
                        <Button Content="{Binding LicenseStatus}" 
                                Command="{Binding ActivateLicenseCommand}"
                                Foreground="{StaticResource PrimaryBrush}" 
                                FontSize="11" FontWeight="Bold" Background="Transparent" BorderThickness="0" Cursor="Hand" VerticalAlignment="Center"/>
                        
                        <Path Data="M9,16.17L4.83,12L3.41,13.41L9,19L21,7L19.59,5.59L9,16.17Z" 
                              Fill="{StaticResource PrimaryBrush}" 
                              Width="14" Height="14" Stretch="Uniform" 
                              Margin="5,0,0,0" VerticalAlignment="Center"
                              Visibility="{Binding IsLicensed, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    </StackPanel>

                    <TextBlock Text="{Binding VersionText}" Foreground="{StaticResource MutedTextBrush}" FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
